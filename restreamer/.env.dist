# datarhei Restreamer
# Docker image:
# https://hub.docker.com/r/datarhei/restreamer
# Docs:
# https://docs.datarhei.com/restreamer

IMAGE_TAG=2.12.0

# Compose helper mode:
#   default - standalone localhost-bound UI with direct ingest ports
#   traefik - also attach to the shared Traefik network and add UI router labels
COMPOSE_VARIANT=default

# Persistent storage.
CONFIG_PATH=./config
DATA_PATH=./data

# Local web UI binding. Keep this localhost-only even when Traefik is enabled.
HTTP_BIND_ADDR=127.0.0.1
HTTP_BIND_PORT=8406

# Direct ingest ports. Restreamer's internal RTMP/SRT servers are enabled from the
# UI/wizard; these mappings only make the host ports available once you do that.
RTMP_BIND_ADDR=0.0.0.0
RTMP_BIND_PORT=1935
SRT_BIND_ADDR=0.0.0.0
SRT_BIND_PORT=6000

# Optional Traefik settings used by COMPOSE_VARIANT=traefik.
# The shared Traefik stack terminates HTTPS, so keep Restreamer TLS/Let's Encrypt disabled.
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_HOST=restreamer.example.com

# Container logging.
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
