# Obscura image tag. Upstream currently publishes a rolling "latest" tag.
IMAGE_TAG=latest

# Compose variant: default, stealth, proxy, stealth_proxy, traefik,
# traefik_stealth, traefik_proxy, or traefik_stealth_proxy.
COMPOSE_VARIANT=default

# Local streamable HTTP MCP endpoint.
BIND_ADDR=127.0.0.1
BIND_PORT=8413

# Optional comma-separated browser Origin allowlist.
OBSCURA_MCP_ALLOWED_ORIGINS=

# Proxy settings used only by proxy variants. The proxy applies to all browser
# requests; Obscura currently has no equivalent of NO_PROXY.
PROXY_NETWORK=proxy
OBSCURA_PROXY=socks5://mihomo:1050

# Optional Traefik settings used only by traefik variants.
TRAEFIK_HOST=mcp-obscura.example.com
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure

# Access policy defaults to default-access@file. Do not use public-access@file
# without adding authentication in front of this unauthenticated MCP endpoint.
TRAEFIK_ACCESS_POLICY=default-access@file

LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
