# MariaDB Server official image
# https://hub.docker.com/_/mariadb
# https://mariadb.com/kb/en/mariadb-server-docker-official-image-environment-variables/

# Image tag. `lts` tracks the current long-term-support branch.
IMAGE_TAG=lts

# Host bindings and local paths.
BIND_ADDR=127.0.0.1
BIND_PORT=3306
HOST_DATA_DIR=./data
HOST_CONFIG_DIR=./config

# Container time zone.
TZ=UTC

# Root password is required. Set a real value before first start.
MARIADB_ROOT_PASSWORD=ChangeMe

# Optional first-run bootstrap variables.
# These only apply when HOST_DATA_DIR is empty.
#MARIADB_DATABASE=app
#MARIADB_USER=app
#MARIADB_PASSWORD=ChangeMe

# Shared database network name.
DATABASES_NETWORK=databases

# Container logging.
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
