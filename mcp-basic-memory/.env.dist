# Basic Memory MCP image tag. Default 'latest' tracks upstream's rapid release
# cadence (GHCR ships releases frequently and tags like 'v0.22.1' / '0.22' are
# common). This is an explicit deviation from the AGENTS.md "prefer explicit
# stable tags over latest" rule, approved for this stack. Pin to a specific
# version such as 'v0.22.1' if reproducibility matters more than tracking
# upstream.
IMAGE_TAG=latest

# Compose variant: default or traefik.
COMPOSE_VARIANT=default

# Optional Traefik settings used by COMPOSE_VARIANT=traefik.
#TRAEFIK_HOST=mcp-basic-memory.example.com
#TRAEFIK_NETWORK=traefik
#TRAEFIK_ENTRYPOINT=websecure

# Access policy defaults to default-access@file (private). Use
# public-access@file only when intentionally exposing this unauthenticated
# MCP endpoint publicly.
#TRAEFIK_ACCESS_POLICY=default-access@file

# Local HTTP endpoint. Keep the default localhost binding unless access is
# protected by another network layer (e.g. Tailnet, Authelia).
BIND_ADDR=127.0.0.1
BIND_PORT=8415

# Host directory mounted to /app/data inside the container. Point this at a
# dedicated memory subdirectory, not your entire Obsidian vault. The
# upstream image sets BASIC_MEMORY_PROJECT_ROOT=/app/data, which constrains
# every registered project path to live underneath this mount; in practice
# each project is a subdirectory like /app/data/<project-name>. The image
# runs as UID/GID 1000; on Linux, run `chown -R 1000:1000 ./memory` (or the
# chosen directory) once before the first start.
HOST_MEMORY_DIR=./memory

# Host directory mounted to /app/data/basic-memory inside the container.
# This is the CLI's "config dir" — the docker-compose.yml sets
# BASIC_MEMORY_CONFIG_DIR=/app/data/basic-memory so resolve_data_dir()
# returns this path. The directory holds config.json, the SQLite index
# (memory.db), watch-status.json, .bmignore, and (by upstream's design)
# the implicit 'main' project — BasicMemoryConfig.model_post_init defaults
# that project's path to BASIC_MEMORY_HOME, which the Dockerfile also
# sets to /app/data/basic-memory. Without the BASIC_MEMORY_CONFIG_DIR
# override the CLI would silently fall back to ~/.basic-memory (i.e.
# /home/appuser/.basic-memory inside the container) and this mount would
# be a no-op. Inside the container this is a subdirectory of the vault
# mount (/app/data/basic-memory inside /app/data); on the host the two
# bind mounts are independent, so the index can be backed up separately
# from the notes. Same UID/GID 1000 requirement applies.
HOST_CONFIG_DIR=./config

# Basic Memory MCP runtime configuration. Defaults match upstream.
BASIC_MEMORY_DEFAULT_PROJECT=main
BASIC_MEMORY_SYNC_CHANGES=true
BASIC_MEMORY_LOG_LEVEL=INFO
BASIC_MEMORY_SYNC_DELAY=1000

# MCP transport: streamable-http (recommended default) or sse (legacy).
# streamable-http is the modern MCP transport (spec 2025-03-26) and is required
# by Codex; OpenCode and Claude Code accept either transport. Override only to
# roll back to the deprecated SSE transport — upstream marks SSE as legacy.
#BASIC_MEMORY_TRANSPORT=streamable-http

LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
