# Tracks upstream's rapid release cadence. Pin to a specific version
# (e.g. v0.22.1) if reproducibility matters more than tracking upstream.
IMAGE_TAG=latest

# Compose variant: default or traefik.
COMPOSE_VARIANT=default

# Used by COMPOSE_VARIANT=traefik.
#TRAEFIK_HOST=mcp-basic-memory.example.com
#TRAEFIK_NETWORK=traefik
#TRAEFIK_ENTRYPOINT=websecure

# default-access@file = default policy chosed for this host (either public or IP whitelist).
# public-access@file = unauthenticated, exposed publicly.
#TRAEFIK_ACCESS_POLICY=default-access@file

# Local HTTP endpoint. Bind to 0.0.0.0 only when the endpoint is protected
# by another network layer (VPN, Tailnet, Authelia).
BIND_ADDR=127.0.0.1
BIND_PORT=8415

# Vault root: one subdirectory per project. Point at a dedicated memory
# directory, not your whole Obsidian vault — Basic Memory rewrites files
# here. Image runs as UID/GID 1000; on Linux, `chown -R 1000:1000` once
# before the first start.
HOST_MEMORY_DIR=./memory

# CLI config dir: config.json, memory.db (SQLite index), watch-status.json,
# .bmignore. Bind-mounted under the vault root; on the host it is a
# separate directory so the index can be backed up independently from
# the notes. Same UID/GID 1000 requirement.
HOST_CONFIG_DIR=./config

# Basic Memory CLI runtime configuration. Defaults match upstream.
BASIC_MEMORY_DEFAULT_PROJECT=main
BASIC_MEMORY_SYNC_CHANGES=true
BASIC_MEMORY_LOG_LEVEL=INFO
BASIC_MEMORY_SYNC_DELAY=1000

# MCP transport. streamable-http is required by Codex; OpenCode and
# Claude Code accept either. Override only to roll back to the deprecated
# SSE transport.
#BASIC_MEMORY_TRANSPORT=streamable-http

LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
