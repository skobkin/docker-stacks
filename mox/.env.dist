# Docker image tag
#IMAGE_TAG=latest

# Compose helper mode:
#   default - Mox manages its configured listeners without Traefik labels
#   traefik - adds Traefik routers while keeping Mox in host network mode
#COMPOSE_VARIANT=default

# Host directories
#HOST_CONFIG_DIR=./config
#HOST_DATA_DIR=./data
#HOST_WEB_DIR=./web

# Optional Traefik settings used by COMPOSE_VARIANT=traefik
#TRAEFIK_ENTRYPOINT=websecure

# MTA-STS and autoconfiguration must be publicly reachable.
#TRAEFIK_PUBLIC_ACCESS_POLICY=public-access@file

# Account, webmail, and WebAPI access remains private by default.
#TRAEFIK_WEB_ACCESS_POLICY=default-access@file

# Mail server hostname used by clients and as the autodiscover SRV target.
TRAEFIK_MAIL_HOST=mail.example.com
# Thunderbird autoconfiguration hostname for the hosted mail domain.
# Normally distinct from TRAEFIK_MAIL_HOST so clients can discover autoconfig.example.com.
TRAEFIK_AUTOCONFIG_HOST=autoconfig.example.com
# MTA-STS policy hostname for the hosted mail domain.
# Must use the standard mta-sts.<domain> name and should not be shared with the other hosts.
TRAEFIK_MTASTS_HOST=mta-sts.example.com

# Plain HTTP ports configured on the Mox listener reachable from Traefik.
#TRAEFIK_STANDARDS_SERVICE_PORT=81
#TRAEFIK_WEB_SERVICE_PORT=1080

# Logging configuration
#LOG_MAX_SIZE=5m
#LOG_MAX_FILE=5
