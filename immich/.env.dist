# You can find documentation for all the supported env variables at https://immich.app/docs/install/environment-variables

BIND_ADDRESS=127.0.0.1
BIND_PORT=2283

# Available modes: shared, internal
# Shared allows to publish database ports on host which may be useful for a backup
# Internal mode leave the database inside the stack network
#DB_MODE=shared
#DB_EXTERNAL_ADDRESS=127.0.0.1
#DB_EXTERNAL_PORT=5430

# The location where your uploaded files are stored
UPLOAD_LOCATION=./library
MODEL_CACHE_LOCATION=./model-cache
# The location where your database files are stored
DB_DATA_LOCATION=./db

# To set a timezone, uncomment the next line and change Etc/UTC to a TZ identifier from this list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones#List
# TZ=Etc/UTC

#HWACCEL_TRANSCODING=vaapi
#HWACCEL_ML=

# The Immich version to use. You can pin this to a specific version like "v1.71.0"
IMMICH_VERSION=release

# Connection secret for postgres. You should change it to a random password
# Please use only the characters `A-Za-z0-9`, without special characters or spaces
DB_PASSWORD=ChangeMe

# The values below this line do not need to be changed
###################################################################################
DB_USERNAME=immich
DB_DATABASE_NAME=immich

LOG_MAX_SIZE=5m
LOG_MAX_FILE=5

# Traefik settings
#
# Compose helper mode:
#   default        - standalone localhost-bound container
#   traefik        - adds Traefik labels and joins external proxy network
#   traefik_dual   - adds private (LAN) and public (WAN) Traefik routers
COMPOSE_VARIANT=default

# External Traefik network name.
TRAEFIK_NETWORK=traefik

# Public hostname for the 'websecure' entrypoint (required when using COMPOSE_VARIANT=traefik or traefik_dual)
#TRAEFIK_HOST=immich.example.com

# Private (LAN) hostname for the 'web' entrypoint (available when using COMPOSE_VARIANT=traefik_dual)
#TRAEFIK_HOST_PRIVATE=immich.lan

# Internal immich port exposed to Traefik.
TRAEFIK_SERVICE_PORT=2283

# Overridable entrypoints for each router (comma-separated list).
# TRAEFIK_ENTRYPOINTS is used when COMPOSE_VARIANT=traefik.
# TRAEFIK_ENTRYPOINTS_PRIVATE and TRAEFIK_ENTRYPOINTS_PUBLIC are used when COMPOSE_VARIANT=traefik_dual.
TRAEFIK_ENTRYPOINTS=websecure
TRAEFIK_ENTRYPOINTS_PRIVATE=web
TRAEFIK_ENTRYPOINTS_PUBLIC=websecure
