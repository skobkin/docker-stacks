# Folding@Home credentials
FAH_USER=skobkin
FAH_TEAM=255284
FAH_PASS=xxx

FAH_POWER=full

# Web interface
HTTP_BIND_ADDR=127.0.0.1
HTTP_BIND_PORT=7396

# Compose helper mode:
#   default - standalone localhost-bound container
#   traefik - adds Traefik labels and joins the external Traefik network
#COMPOSE_VARIANT=default

# Optional Traefik settings used by COMPOSE_VARIANT=traefik
#TRAEFIK_HOST=foldingathome.example.com
#TRAEFIK_ENTRYPOINT=websecure

# Access policy defaults to default-access@file. Use public-access@file only when explicitly exposing the stack.
#TRAEFIK_ACCESS_POLICY=default-access@file

#TRAEFIK_SERVICE_PORT=7396

# Logs
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
