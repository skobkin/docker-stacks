# Optional catch-all redirect for hostnames that are not matched by any more
# specific Docker or file-provider router.
#
# Copy this file to unknown-host-redirect.yml, then replace the redirect target
# with the canonical URL for this Traefik instance. Keep this redirect temporary
# so browsers do not cache redirects for hostnames you may add later.

http:
  routers:
    unknown-host-redirect:
      entryPoints:
        - web
        - websecure
      rule: "HostRegexp(`^.+$`)"
      priority: 1
      middlewares:
        - unknown-host-redirect
      service: noop@internal

  middlewares:
    unknown-host-redirect:
      redirectRegex:
        regex: "^https?://.*"
        replacement: "https://traefik.example.com/"
        permanent: false
