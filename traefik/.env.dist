# Traefik
# Docker provider docs:
# https://doc.traefik.io/traefik/reference/install-configuration/providers/docker/
# File provider docs:
# https://doc.traefik.io/traefik/reference/install-configuration/providers/others/file/
# ACME docs:
# https://doc.traefik.io/traefik/reference/install-configuration/tls/certificate-resolvers/acme/

# Docker images
IMAGE_REPOSITORY=traefik
# `v3` follows the current Traefik v3 release line and picks up patched v3 images automatically.
IMAGE_TAG=v3
SOCKET_PROXY_IMAGE_REPOSITORY=tecnativa/docker-socket-proxy
# `latest` follows the latest released docker-socket-proxy image. Upstream reserves `edge` for the master branch.
SOCKET_PROXY_IMAGE_TAG=latest

# Compose reads .env automatically; ENV_FILE is only needed for validation or alternate env file names.
#ENV_FILE=.env

# Host bindings and local paths
HTTP_BIND_ADDR=0.0.0.0
HTTP_BIND_PORT=80
HTTPS_BIND_ADDR=0.0.0.0
HTTPS_BIND_PORT=443
CONFIG_PATH=./config
DATA_PATH=./data
SECRETS_PATH=./secrets
DOCKER_SOCK_PATH=/var/run/docker.sock

# Shared reverse-proxy network for Traefik and proxied stacks.
TRAEFIK_NETWORK=traefik

# Dashboard domain.
# Traefik serves the dashboard and API on this host under `/dashboard/` and `/api`.
# Reusing a host already used by another service can conflict if that service also needs those paths.
TRAEFIK_DASHBOARD_HOST=traefik.example.com

# Container logging
#LOG_MAX_SIZE=5m
#LOG_MAX_FILE=5
SOCKET_PROXY_LOG_LEVEL=warning

##### Traefik static configuration (passed as environment variables)

TRAEFIK_API=true
TRAEFIK_API_DASHBOARD=true
TRAEFIK_API_INSECURE=false

TRAEFIK_PROVIDERS_DOCKER=true
TRAEFIK_PROVIDERS_DOCKER_ENDPOINT=tcp://socket-proxy:2375
TRAEFIK_PROVIDERS_DOCKER_EXPOSEDBYDEFAULT=false
TRAEFIK_PROVIDERS_DOCKER_WATCH=true
# Set automatically by docker-compose.yml from TRAEFIK_NETWORK:
#TRAEFIK_PROVIDERS_DOCKER_NETWORK=traefik

TRAEFIK_PROVIDERS_FILE_DIRECTORY=/etc/traefik/dynamic
TRAEFIK_PROVIDERS_FILE_WATCH=true

TRAEFIK_ENTRYPOINTS_WEB_ADDRESS=:80
TRAEFIK_ENTRYPOINTS_WEB_HTTP_REDIRECTIONS_ENTRYPOINT_TO=websecure
TRAEFIK_ENTRYPOINTS_WEB_HTTP_REDIRECTIONS_ENTRYPOINT_SCHEME=https
TRAEFIK_ENTRYPOINTS_WEB_HTTP_REDIRECTIONS_ENTRYPOINT_PERMANENT=true

TRAEFIK_ENTRYPOINTS_WEBSECURE_ADDRESS=:443
TRAEFIK_ENTRYPOINTS_WEBSECURE_HTTP_TLS=true
TRAEFIK_ENTRYPOINTS_WEBSECURE_HTTP_TLS_CERTRESOLVER=default

# Trust forwarded headers only from your upstream reverse proxy or CDN.
# Set both entrypoints when Traefik sits behind another proxy or Cloudflare.
#TRAEFIK_ENTRYPOINTS_WEB_FORWARDEDHEADERS_TRUSTEDIPS=
#TRAEFIK_ENTRYPOINTS_WEBSECURE_FORWARDEDHEADERS_TRUSTEDIPS=

# Automatic certificates via Let's Encrypt HTTP-01 on the web entrypoint.
TRAEFIK_CERTIFICATESRESOLVERS_DEFAULT_ACME_EMAIL=admin@example.com
TRAEFIK_CERTIFICATESRESOLVERS_DEFAULT_ACME_STORAGE=/var/lib/traefik/acme/acme.json
TRAEFIK_CERTIFICATESRESOLVERS_DEFAULT_ACME_HTTPCHALLENGE_ENTRYPOINT=web

# Optional staging CA while testing ACME to avoid Let's Encrypt production rate limits.
#TRAEFIK_CERTIFICATESRESOLVERS_DEFAULT_ACME_CASERVER=https://acme-staging-v02.api.letsencrypt.org/directory

# Optional DNS-01 setup for wildcard certificates or environments where HTTP-01 does not fit.
# To switch fully to DNS-01:
# 1. comment out TRAEFIK_CERTIFICATESRESOLVERS_DEFAULT_ACME_HTTPCHALLENGE_ENTRYPOINT above
# 2. uncomment the DNS challenge settings below
# 3. add the provider-specific credential environment variables required by Traefik
#TRAEFIK_CERTIFICATESRESOLVERS_DEFAULT_ACME_DNSCHALLENGE_PROVIDER=cloudflare
#TRAEFIK_CERTIFICATESRESOLVERS_DEFAULT_ACME_DNSCHALLENGE_RESOLVERS=1.1.1.1:53,8.8.8.8:53
# Example provider credential for Cloudflare:
#CF_DNS_API_TOKEN=

# Logging and troubleshooting
TRAEFIK_LOG_LEVEL=INFO
#TRAEFIK_ACCESSLOG=true
