# ESPHome Configuration
IMAGE_TAG=latest

HOST_CONFIG_DIR=./config

HOST_BIND_IP=127.0.0.1
HOST_PORT=6052

# Dashboard ping setting (set to true for MacOS)
#DASHBOARD_USE_PING=false

# Logging configuration
ESPHOME_LOG_LEVEL=INFO
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5

# Optional Traefik reverse proxy support.
# Set COMPOSE_VARIANT=traefik to enable Traefik labels.
#COMPOSE_VARIANT=default

# Traefik entrypoint used by the ESPHome router (e.g., web or websecure).
#TRAEFIK_ENTRYPOINT=websecure

# Public hostname served by Traefik for ESPHome (required when COMPOSE_VARIANT=traefik).
#TRAEFIK_HOST=esphome.example.com

# Internal ESPHome port exposed to Traefik.
#TRAEFIK_SERVICE_PORT=6052
