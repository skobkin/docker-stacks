# VictoriaLogs - log storage and web UI.
# https://docs.victoriametrics.com/victorialogs/

# Docker image
#VL_IMAGE_REPOSITORY=victoriametrics/victoria-logs
#VL_IMAGE_TAG=v1.51.0

# Compose helper mode:
#   default - localhost-bound container on the 'logging' network
#   traefik - additionally publishes the UI through the shared Traefik stack
#             behind Authelia
#COMPOSE_VARIANT=default

# Bind address. Override to a LAN IP (or 0.0.0.0) when running the fluent-bit
# stack in 'remote' variant on a different host pointing at this VictoriaLogs.
VL_BIND_ADDRESS=127.0.0.1
VL_BIND_PORT=9428

# Persistent data path. The directory holds the VictoriaLogs storage.
VL_DATA_PATH=./data

# Retention. Oldest entries are evicted first.
VL_RETENTION_PERIOD=30d
VL_MAX_DISK_USAGE=50GiB

# Memory budget. VictoriaLogs is allowed to use up to this percentage of the
# host RAM for in-memory caches.
VL_MEMORY_ALLOWED_PERCENT=40

# Networking (same-host fluent-bit needs this network)
#LOGGING_NETWORK=logging

# Optional Traefik settings used by COMPOSE_VARIANT=traefik.
# Replace the host before enabling the variant.
#TRAEFIK_NETWORK=traefik
#VL_TRAEFIK_ENTRYPOINT=websecure
#VL_TRAEFIK_HOST=logs.example.com
#VL_TRAEFIK_MIDDLEWARES=default-access@file,authelia@file

# Repo logging convention (size per rotated file, max number of files).
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5