# OpenWebRX+ image docs:
# https://luarvique.github.io/ppa/#if-you-are-using-docker-
# https://fms.komkon.org/OWRX/#INSTALL-DOCKER
# OpenWebRX Docker reference:
# https://github.com/jketterl/openwebrx/wiki/Setup-Guide#docker

# Image selection
# Default uses plus image with preinstalled MBE decoder package.
# Override IMAGE_REPOSITORY to use another OpenWebRX/OpenWebRX+ image.
IMAGE_REPOSITORY=slechev/openwebrxplus-softmbe
IMAGE_TAG=latest
#CONTAINER_NAME=openwebrxplus

# HTTP binding
#WEB_BIND_ADDR=127.0.0.1
#WEB_BIND_PORT=8402

# Host mounts
# /etc/openwebrx inside container
#HOST_ETC_DIR=./etc
# /var/lib/openwebrx inside container
#HOST_VAR_DIR=./var
# /opt/openwebrx/plugins inside container
#HOST_PLUGINS_DIR=./plugins

# SDR device passthrough
# Default works for USB SDRs including AirSpy Mini.
#USB_DEVICE_PATH=/dev/bus/usb

# Initial admin account (change password before production use)
OPENWEBRX_ADMIN_USER=admin
OPENWEBRX_ADMIN_PASSWORD=changeme

# Runtime settings
TZ=Etc/UTC

# In-RAM temporary workspace mount
# Keep /tmp on tmpfs for better decoder I/O performance.
#TMPFS_TARGET=/tmp
#TMPFS_MODE=1777
#TMPFS_SIZE=256m

# Logging
#LOG_MAX_SIZE=5m
#LOG_MAX_FILE=5
