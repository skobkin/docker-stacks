# Mihomo image tag used by the official Docker example.
IMAGE_TAG=Alpha

# Compose helper mode:
#   default - joins the proxy network and keeps the controller localhost-bound
#   traefik - additionally publishes the controller API through Traefik
#COMPOSE_VARIANT=default

# Proxy listeners compatible with the current v2fly-client defaults.
# These container ports are rendered into config/config.yaml on container start.
SOCKS_BIND_ADDRESS=0.0.0.0
SOCKS_HOST_PORT=1050
SOCKS_CONTAINER_PORT=1050

HTTP_BIND_ADDRESS=0.0.0.0
HTTP_HOST_PORT=1080
HTTP_CONTAINER_PORT=1080

TPROXY_BIND_ADDRESS=0.0.0.0
TPROXY_HOST_PORT=12345
TPROXY_CONTAINER_PORT=12345

# Controller API. Keep the host binding local unless you intentionally publish it.
CONTROLLER_BIND_ADDRESS=127.0.0.1
CONTROLLER_HOST_PORT=9092
CONTROLLER_CONTAINER_PORT=9090

# Replace before first start. Mihomo controller auth uses this bearer token.
CONTROLLER_SECRET=change-me

# Optional Traefik settings used by COMPOSE_VARIANT=traefik.
# Publish the controller only with TLS and a strong secret.
#TRAEFIK_NETWORK=traefik
#TRAEFIK_ENTRYPOINT=websecure
#TRAEFIK_HOST=mihomo.example.com

LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
