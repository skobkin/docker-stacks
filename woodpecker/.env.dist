# see https://woodpecker-ci.org/docs/administration/general

IMAGE_TAG=v3

HOST_DATA_DIR=./data

# Compose helper mode:
#   default - standalone localhost-bound HTTP/gRPC ports
#   databases - also attach Woodpecker to the shared databases network
#   traefik - also attach Woodpecker to the shared Traefik network
#   traefik_databases - combine Traefik and shared databases networking
COMPOSE_VARIANT=default

#HOST_CERT_DIR=/etc/certs/woodpecker
#WOODPECKER_SERVER_CERT=/etc/certs/woodpecker/cert.crt
#WOODPECKER_SERVER_KEY=/etc/certs/woodpecker/cert.key

WEBUI_BIND_ADDR=127.0.0.1
WEBUI_BIND_PORT=8400

GRPC_BIND_ADDR=127.0.0.1
GRPC_BIND_PORT=9400

# Optional Traefik settings used by COMPOSE_VARIANT=traefik or traefik_databases.
# The web UI is proxied on the shared HTTPS entrypoint; the gRPC endpoint uses
# the shared gRPC-over-HTTPS entrypoint exposed by the Traefik stack.
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_GRPC_ENTRYPOINT=grpcsecure
TRAEFIK_HOST=woodpecker.domain.tld
TRAEFIK_SERVICE_PORT=8000
TRAEFIK_GRPC_SERVICE_PORT=9000

# Optional shared database network used by COMPOSE_VARIANT=databases or traefik_databases.
DATABASES_NETWORK=databases

# Woodpecker server settings
# https://woodpecker-ci.org/docs/administration/configuration/server
WOODPECKER_HOST=https://woodpecker.domain.tld
WOODPECKER_ADMIN=admin-user
WOODPECKER_OPEN=true
WOODPECKER_AGENT_SECRET=super-duper-secret

# VCS provider
# See https://woodpecker-ci.org/docs/administration/configuration/forges/overview
WOODPECKER_FORGEJO=true
# This will be used for authorization redirect, so public URL is needed
WOODPECKER_FORGEJO_URL=https://forgejo.domain.tld
# Forgejo OAuth client id
WOODPECKER_FORGEJO_CLIENT=YOUR_FORGEJO_CLIENT
# Forgejo OAuth client secret
WOODPECKER_FORGEJO_SECRET=YOUR_FORGEJO_CLIENT_SECRET

# Database (SQLite by default at /var/lib/woodpecker/woodpecker.sqlite)
# SQLite
#WOODPECKER_DATABASE_DRIVER=sqlite3
#WOODPECKER_DATABASE_DATASOURCE=/var/lib/woodpecker/woodpecker.sqlite
#WOODPECKER_DATABASE_SECRET=zzz
# MySQL
#WOODPECKER_DATABASE_DRIVER=mysql
#WOODPECKER_DATABASE_DATASOURCE=root:password@tcp(1.2.3.4:3306)/woodpecker?parseTime=true
# PostgreSQL
#WOODPECKER_DATABASE_DRIVER=postgres
#WOODPECKER_DATABASE_DATASOURCE=postgres://root:password@1.2.3.4:5432/postgres?sslmode=disable

# Service settings
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
