# InvokeAI Configuration
# Copy this file to .env and customize as needed

# GPU driver configuration: 'rocm' for AMD GPUs, 'cuda' for NVIDIA GPUs
GPU_DRIVER=rocm

# Image tag - use 'main-rocm' for AMD or 'main-cuda' for NVIDIA
# Available tags: https://github.com/invoke-ai/InvokeAI/pkgs/container/invokeai
IMAGE_TAG=main-rocm
#IMAGE_TAG=main-cuda

# Network binding
BIND_ADDRESS=127.0.0.1
BIND_PORT=9090

# Data directories
# Main InvokeAI data directory (models, outputs, database)
DATA_DIR=./data
# HuggingFace cache directory (downloaded models and datasets)
HF_CACHE_DIR=./cache/huggingface

# Container user/group IDs (for file permissions)
CONTAINER_UID=1000
CONTAINER_GID=1000

# InvokeAI configuration
INVOKEAI_ROOT=/invokeai

# Optional: Hugging Face token for downloading private models
# Get your token from: https://huggingface.co/settings/tokens
#HUGGING_FACE_HUB_TOKEN=

# Logging configuration
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5

# Optional Traefik reverse proxy support.
# Set COMPOSE_VARIANT=traefik to attach the service to the Traefik network.
#COMPOSE_VARIANT=default

# External Traefik network name.
#TRAEFIK_NETWORK=traefik

# Traefik entrypoint used by the InvokeAI router (e.g., web or websecure).
#TRAEFIK_ENTRYPOINT=websecure

# Access policy defaults to default-access@file. Use public-access@file only when explicitly exposing the stack.
#TRAEFIK_ACCESS_POLICY=default-access@file

# Public hostname served by Traefik for InvokeAI.
#TRAEFIK_HOST=invokeai.example.com

# Internal InvokeAI port exposed to Traefik.
#TRAEFIK_SERVICE_PORT=9090