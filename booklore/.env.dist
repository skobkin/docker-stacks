# BookLore - self-hosted book collection manager
# https://github.com/booklore-app/booklore

# Docker image
#IMAGE_TAG=latest

# Compose helper mode:
#   default  - standalone localhost-bound container
#   traefik  - adds Traefik labels and joins external proxy network
COMPOSE_VARIANT=default

# Host bindings and local paths
WEBUI_BIND_ADDR=127.0.0.1
WEBUI_BIND_PORT=6060

# Container time zone
TZ=Europe/Moscow

# Application user/group IDs
APP_USER_ID=1000
APP_GROUP_ID=1000

# Database storage type: LOCAL (default, enables file operations) or NETWORK (disables file ops for NAS/NFS)
# See: https://github.com/booklore-app/booklore/blob/develop/README.md#-network-storage-nas--nfs--smb--cifs
DISK_TYPE=LOCAL

# Host data directories
HOST_DATA_DIR=./data
HOST_BOOKS_DIR=./books
HOST_BOOKDROP_DIR=./bookdrop

# Traefik settings
TRAEFIK_NETWORK=traefik

# Hostname for the selected Traefik entrypoint.
TRAEFIK_HOST=booklore.example.com

# Overridable Traefik entrypoint.
TRAEFIK_ENTRYPOINT=websecure

# Access policy defaults to default-access@file. Use public-access@file only when explicitly exposing the stack.
#TRAEFIK_ACCESS_POLICY=default-access@file

TRAEFIK_SERVICE_PORT=6060

# Container logging
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5

##### Database configuration
# External MariaDB/MySQL database connection.
# For a database running on the Docker host, use host.docker.internal (default).
# For the shared databases network, use the network gateway IP documented in
# _docs/databases_network.md.
DATABASE_HOST=host.docker.internal
DATABASE_PORT=3306

# Do not use placeholder values — set real credentials before deploying.
DB_USER=booklore
DB_PASSWORD=ChangeMe
DB_NAME=booklore

# Shared database network name. The network must be created before starting the stack.
DATABASES_NETWORK=databases
