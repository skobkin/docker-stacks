# see https://github.com/PurpleI2P/i2pd/blob/openssl/contrib/docker/Dockerfile

# Host
HOST_DATA_DIR=./data
HOST_USER=1000

# Traefik Reverse Proxy (optional: set COMPOSE_VARIANT=traefik and uncomment TRAEFIK_HOST)
#COMPOSE_VARIANT=traefik
#TRAEFIK_HOST=i2pd.example.com
#TRAEFIK_ENTRYPOINTS=websecure

# Access policy defaults to default-access@file. Use public-access@file only when explicitly exposing the stack.
#TRAEFIK_ACCESS_POLICY=default-access@file

#TRAEFIK_SERVICE_PORT=7070

# Container
I2PD_HOME=/home/i2pd
DATA_DIR=/home/i2pd/data
#DEFAULT_ARGS=" --datadir=$DATA_DIR --reseed.verify=true --upnp.enabled=false --http.enabled=true --http.address=0.0.0.0 --httpproxy.enabled=true --httpproxy.address=0.0.0.0 --socksproxy.enabled=true --socksproxy.address=0.0.0.0 --sam.enabled=true --sam.address=0.0.0.0"

# Service
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5