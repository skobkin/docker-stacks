# Current tagged metacubexd image from the official GitHub package.
IMAGE_TAG=v1.218.0

# Compose helper mode:
#   default - standalone localhost-bound dashboard
#   traefik - adds Traefik labels and joins the external Traefik network
#COMPOSE_VARIANT=default

WEBUI_BIND_ADDRESS=127.0.0.1
WEBUI_HOST_PORT=8404
WEBUI_CONTAINER_PORT=80

# Optional browser-reachable controller URL used as the initial backend.
# Leave commented out if you want to choose or add backends manually in the UI.
#DEFAULT_BACKEND_URL=http://127.0.0.1:9092

# Optional Traefik settings used by COMPOSE_VARIANT=traefik.
#TRAEFIK_NETWORK=traefik
#TRAEFIK_ENTRYPOINT=websecure
#TRAEFIK_HOST=metacubexd.example.com

LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
