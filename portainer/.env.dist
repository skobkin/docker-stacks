# https://hub.docker.com/r/portainer/portainer

# Uncomment to use directory binding instead of docker volume (almost always not needed)
#DATA_PATH=/some/path

# Network Configuration
#HTTP_BIND_ADDR=127.0.0.1
#HTTP_BIND_PORT=9000

# Traefik Reverse Proxy (optional: set COMPOSE_VARIANT=traefik and uncomment TRAEFIK_HOST)
#TRAEFIK_HOST=portainer.example.com
#TRAEFIK_ENTRYPOINTS=websecure

# Access policy defaults to default-access@file. Use public-access@file only when explicitly exposing the stack.
#TRAEFIK_ACCESS_POLICY=default-access@file

#TRAEFIK_SERVICE_PORT=9000

LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
