# https://miniflux.app/docs/docker.html
# https://miniflux.app/docs/configuration.html

#IMAGE_TAG=2.2.15

# Compose helper mode:
#   default - standalone localhost-bound HTTP port
#   databases - also attach Miniflux to the shared databases network
#   traefik - also attach Miniflux to the shared Traefik network
#   traefik_databases - combine Traefik and shared databases networking
COMPOSE_VARIANT=default

WEB_BIND_ADDRESS=127.0.0.1
WEB_BIND_PORT=8390

# Optional Traefik settings used by COMPOSE_VARIANT=traefik or traefik_databases.
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_HOST=miniflux.domain.tld
TRAEFIK_SERVICE_PORT=8080

# Optional shared database network used by COMPOSE_VARIANT=databases or traefik_databases.
DATABASES_NETWORK=databases

# Keep BASE_URL in sync with the host/port you're using (required).
BASE_URL=http://localhost:8390/

# For COMPOSE_VARIANT=databases, use the databases network gateway IP
# documented in _docs/databases_network.md.
DATABASE_URL=postgres://miniflux:change-me@host.docker.internal:5432/miniflux?sslmode=disable

RUN_MIGRATIONS=1

# One-time bootstrap (disable after first successful start).
CREATE_ADMIN=1
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Maintenance
#MAINTENANCE_MODE=1

# Metrics
METRICS_COLLECTOR=0
