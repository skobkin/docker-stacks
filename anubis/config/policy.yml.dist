## Anubis bot policy for a multi-service self-hosted instance.
##
## Intent:
## - allow clearly benign clients and infrastructure probes;
## - allow maintained upstream list of good search crawlers;
## - keep API/federation machine endpoints usable;
## - challenge suspicious traffic;
## - hard-deny the really noisy scanner/scraper classes.
##
## Notes:
## - Rule order matters. ALLOW/DENY/CHALLENGE are terminal actions.
## - If no bot rule matches, Anubis defaults to allowing the request.
## - Rules with multiple matchers/expressions are effectively ANDed on current
##   Anubis releases.
## - Host-specific rules require Anubis to see the original Host header.

bots:
  ###########################################################################
  # Per-host / per-service machine endpoint bypasses.
  #
  # Put these before generic bot/browser challenge rules. Otherwise server-side
  # API clients, webhooks, federation delivery, and health checks can get stuck
  # behind a challenge they cannot solve.
  ###########################################################################

  # Forgejo on git.domain.tld:
  # - /api and /api/* covers Forgejo API, including commit status updates from CI.
  # - /login/oauth/access_token is needed by OAuth clients such as CI integrations.
  #
  # This is intentionally broad for the API. If you expose sensitive unauthenticated
  # API routes later, narrow this rule by method, source IP, or path.
  - name: forgejo-api
    action: ALLOW
    expression:
      all:
        - 'host.matches("^git\\.domain\\.tld(?::443)?$")'
        - 'path.matches("^/(api(?:/|$)|login/oauth/access_token$)")'

  # Optional: allow Forgejo smart HTTP Git endpoints for non-browser Git clients.
  # Uncomment only if Anubis breaks git clone/fetch/push over HTTPS.
  #
  # - name: forgejo-git-smart-http
  #   action: ALLOW
  #   expression:
  #     all:
  #       - 'host.matches("^git\\.domain\\.tld(?::443)?$")'
  #       - 'path.matches("^/.+\\.git/(?:info/refs|git-upload-pack|git-receive-pack)$")'
  #       - 'userAgent.matches("^(git/|JGit/)")'

  # Optional: Woodpecker CI on ci.domain.tld.
  # Useful when Forgejo sends webhooks to Woodpecker and Woodpecker API clients
  # must not be interrupted by Anubis challenges.
  #
  # - name: woodpecker-api-and-webhooks
  #   action: ALLOW
  #   expression:
  #     all:
  #       - 'host.matches("^ci\\.domain\\.tld(?::443)?$")'
  #       - 'path.matches("^/(api(?:/|$)|hook$|webhook(?:/|$))")'

  # Optional: GoToSocial on gts.domain.tld.
  # Allows ActivityPub delivery/discovery and Mastodon-compatible API clients.
  # GoToSocial/fediverse federation will break if inbox/webfinger/nodeinfo routes
  # are challenged.
  #
  # - name: gotosocial-activitypub-and-api
  #   action: ALLOW
  #   expression:
  #     all:
  #       - 'host.matches("^gts\\.domain\\.tld(?::443)?$")'
  #       - 'path.matches("^/(api(?:/|$)|users/[^/]+/(?:inbox|outbox|followers|following|collections/featured)(?:/|$)|inbox$|sharedInbox$|nodeinfo(?:/|$)|\\.well-known/(?:webfinger|nodeinfo|host-meta)(?:/|$))")'

  # Optional example: allow only a JSON API on a specific host.
  # This is safer than allowing all paths for a user-agent.
  #
  # - name: example-json-api-only
  #   action: ALLOW
  #   expression:
  #     all:
  #       - 'host.matches("^api\\.example\\.net(?::443)?$")'
  #       - 'path.startsWith("/v1/")'
  #       - '"Accept" in headers'
  #       - 'headers["Accept"].contains("application/json")'

  # Optional example: allow trusted internal monitors.
  # Be careful: if Anubis sees only your reverse proxy IP as remoteAddress, this
  # would allow everyone. Use only when real client IP handling is correct.
  #
  # - name: example-internal-monitoring
  #   action: ALLOW
  #   user_agent_regex: ^(?:Gatus/1\.0|Prometheus/.*)$
  #   remote_addresses:
  #     - 192.168.1.0/24
  #     - 172.19.0.0/24

  # Good crawlers that are expected to respect robots policy:
  # Google, Apple, Bing, DuckDuckGo, Qwant, Internet Archive, Kagi, Marginalia,
  # Mojeek, Common Crawl, Wikimedia Citoid, Yandex, etc. Exact contents depend
  # on your installed Anubis version.
  #
  # Keep this before emergency Forgejo deny rules. Some legitimate crawler UAs
  # contain "Mozilla" and may request deep links without a Referer.
  - import: (data)/crawlers/_allow-good.yaml

  ###########################################################################
  # Forgejo emergency anti-DDoS rules.
  #
  # These target web UI scraping of expensive repository history/file routes.
  # They intentionally do NOT affect:
  # - Forgejo API rules above;
  # - good search crawlers allowed below;
  # - optional Git smart HTTP rule above, if you enable it.
  #
  # Tradeoff: direct external links to old commit/tree/raw/blame pages may be
  # blocked or strongly challenged while these rules are enabled. Normal browsing
  # from inside Forgejo should still work because it carries a same-host Referer.
  ###########################################################################

  # The current attack pattern: browser-looking clients hit expensive deep
  # commit tree/raw/blame/history pages. Challenge these hard regardless of
  # Referer.
  - name: forgejo-challenge-deep-history-pages
    action: CHALLENGE
    expression:
      all:
        - 'host.matches("^git\\.domain\\.tld(?::443)?$")'
        - 'method in ["GET", "HEAD"]'
        - 'userAgent.matches("(?i)(Mozilla|Chrome|Firefox|Safari|AppleWebKit|Gecko)")'
        - 'path.matches("^/[^/]+/[^/]+/(?:src/commit/[0-9a-f]{40}(?:/|$)|raw/commit/[0-9a-f]{40}(?:/|$)|blame/commit/[0-9a-f]{40}(?:/|$)|commits/commit/[0-9a-f]{40}(?:/|$)|commit/[0-9a-f]{40}(?:/|$))")'
    challenge:
      algorithm: fast
      difficulty: 8

  # Strongly challenge other Forgejo web UI repository pages. This catches
  # browser-looking scrapers before the generic low-difficulty browser rule.
  - name: forgejo-challenge-repo-web-ui
    action: CHALLENGE
    expression:
      all:
        - 'host.matches("^git\\.domain\\.tld(?::443)?$")'
        - 'method in ["GET", "HEAD"]'
        - 'userAgent.matches("(?i)(Mozilla|Chrome|Firefox|Safari|AppleWebKit|Gecko)")'
        - 'path.matches("^/[^/]+/[^/]+/(?:src|raw|blame|commits|commit|compare|pulls|issues|releases|activity|graph)(?:/|$)")'
    challenge:
      algorithm: fast
      difficulty: 5

  # Diagnostic rule. Temporarily uncomment to prove whether git.domain.tld
  # requests are evaluated by Anubis at all:
  #
  #   curl -kI https://git.domain.tld/.anubis-policy-test
  #
  # Expected while enabled: Anubis challenge response/log entry.
  # If Forgejo or Traefik answers instead, the request is bypassing Anubis.
  #
  # - name: forgejo-anubis-policy-test
  #   action: CHALLENGE
  #   expression:
  #     all:
  #       - 'host.matches("^git\\.domain\\.tld(?::443)?$")'
  #       - 'path == "/.anubis-policy-test"'
  #   challenge:
  #     algorithm: fast
  #     difficulty: 1

  # Optional harsher mode:
  # During a heavy attack, uncomment this to deny *all* direct no-referrer access
  # to Forgejo repo pages, not just commit-SHA history routes. This can break
  # external links to files/repositories, so keep it as an emergency switch.
  #
  # - name: forgejo-deny-direct-repo-web-ui-emergency
  #   action: DENY
  #   expression:
  #     all:
  #       - 'host.matches("^git\\.domain\\.tld(?::443)?$")'
  #       - 'method == "GET"'
  #       - 'userAgent.matches("(?i)(Mozilla|Chrome|Firefox|Safari|AppleWebKit|Gecko)")'
  #       - 'path.matches("^/[^/]+/[^/]+/(?:src|raw|blame|commits|commit)(?:/|$)")'
  #       - 'missingHeader(headers, "Referer")'

  ###########################################################################
  # Explicitly allowed non-browser infrastructure clients.
  ###########################################################################

  # Gatus default HTTP check user-agent.
  # Better: restrict by remote_addresses if this Anubis instance sees Gatus'
  # real source IP.
  - name: gatus-default-client
    user_agent_regex: ^Gatus/1\.0$
    action: ALLOW

  # Default Go net/http client.
  # This is intentionally permissive and spoofable. Many bots and throwaway
  # tools also use this UA. Keep this only if you really want generic Go clients
  # to bypass challenges.
  - name: golang-default-client
    user_agent_regex: ^Go-http-client/(?:1\.1|2\.0)$
    action: ALLOW

  ###########################################################################
  # Upstream maintained allow/deny lists.
  ###########################################################################

  # Common public routes that should remain reachable.
  - import: (data)/common/keep-internet-working.yaml

  # Pathological bot/scanner rules maintained upstream. At the time of writing,
  # this includes Cloudflare Workers abuse, headless browsers, us-ai-scraper,
  # Custom-AsyncHttpClient, Alibaba Cloud, and Huawei Cloud.
  - import: (data)/bots/_deny-pathological.yaml

  # AI/LLM crawlers. Use the aggressive preset for a small self-hosted site.
  # If this blocks too much, replace with:
  # - import: (data)/meta/ai-block-moderate.yaml
  # - import: (data)/meta/ai-block-permissive.yaml
  - import: (data)/meta/ai-block-aggressive.yaml

  # x.ai scraper pressure has been called out by newer upstream Anubis defaults,
  # but some released/container builds do not ship (data)/crawlers/xai.yaml yet.
  # Keep this commented unless `anubis` in your image can resolve it.
  #
  # - import: (data)/crawlers/xai.yaml

  ###########################################################################
  # Extra hard-deny rules for noisy scanners and hostile automation.
  ###########################################################################

  - name: internet-wide-scanners
    action: DENY
    user_agent_regex: >-
      (?i)(?:CensysInspect|zgrab|masscan|Nuclei|sqlmap|Nikto|OpenVAS|Nessus|Acunetix|Qualys|ZmEu|Morfeus|DirBuster|GoBuster|ffuf|wpscan|WhatWeb|Shodan|Palo Alto Networks|Expanse)

  - name: abusive-cloud-scrapers
    action: DENY
    user_agent_regex: >-
      (?i)(?:Alibaba|Aliyun|Huawei|HuaweiCloud|Tencent|Bytespider|PetalBot|BLEXBot|DataForSeoBot|SeekportBot|SemrushBot|AhrefsBot|DotBot|MJ12bot|Barkrowler)

  - name: obvious-exploit-paths
    action: DENY
    path_regex: >-
      (?i)^/(?:\.env|\.git/|wp-admin/|wp-login\.php|xmlrpc\.php|vendor/phpunit|cgi-bin/|boaform/|HNAP1|setup\.cgi|solr/|actuator/|manager/html|phpmyadmin|pma|_profiler|server-status)(?:/|$)

  - name: cloudflare-workers
    headers_regex:
      CF-Worker: .*
    action: DENY

  ###########################################################################
  # Suspicious clients: challenge, do not deny.
  #
  # Good crawlers and explicitly allowed clients above bypass these rules first.
  ###########################################################################

  - name: suspicious-bot-user-agents
    action: CHALLENGE
    user_agent_regex: >-
      (?i)(?:bot|crawler|spider|scraper|archiver|indexer|fetcher|harvest|extract|scan)
    challenge:
      algorithm: fast
      difficulty: 8

  - name: suspicious-http-libraries
    action: CHALLENGE
    user_agent_regex: >-
      (?i)^(?:curl|Wget|python-requests|Python-urllib|aiohttp|httpx|libwww-perl|Java/|Apache-HttpClient|okhttp|Ruby|Mechanize|Scrapy|node-fetch|axios|undici|PostmanRuntime|Insomnia|HTTPie)
    challenge:
      algorithm: fast
      difficulty: 7

  - name: headless-or-automation-frameworks
    action: CHALLENGE
    user_agent_regex: >-
      (?i)(?:HeadlessChrome|PhantomJS|SlimerJS|Selenium|Playwright|Puppeteer|Cypress|Chrome-Lighthouse)
    challenge:
      algorithm: fast
      difficulty: 9

  # Browser-like clients get a direct proof-of-work challenge.
  # This is intentionally stricter than upstream defaults for periods when
  # browser-looking botnets are scraping Forgejo through the web UI.
  - name: generic-browser
    user_agent_regex: >-
      Mozilla|Opera
    action: CHALLENGE
    challenge:
      algorithm: fast
      difficulty: 5

  ###########################################################################
  # Optional Thoth-only ASN / GeoIP rules.
  #
  # Uncomment only if your Anubis build/deployment has Thoth data available.
  ###########################################################################

  # - name: aggressive-cloud-asns
  #   action: DENY
  #   asns:
  #     match:
  #       - 45102  # Alibaba Cloud
  #       - 136907 # Huawei Cloud
  #       - 132203 # Tencent Cloud
  #       - 14618  # AWS
  #       - 16509  # AWS

  # - name: high-scraper-pressure-countries
  #   action: WEIGH
  #   geoip:
  #     countries:
  #       - BR
  #       - CN
  #   weight:
  #     adjust: 10

openGraph:
  enabled: false
  considerHost: true
  ttl: 24h

# For a single Anubis instance this is okay. For production or multiple
# instances, prefer bbolt or valkey.
store:
  backend: memory
  parameters: {}

# IMPORTANT for Traefik forwardAuth:
# - Any 2xx response from the auth service means "allowed".
# - Therefore CHALLENGE must NOT be 200 when Anubis is used as forwardAuth.
# - Use 401 so Traefik stops the request and returns/displays Anubis' challenge.
#
# The upstream default CHALLENGE: 200 is useful in reverse-proxy mode to confuse
# dumb scrapers, but it bypasses protection in forwardAuth mode.
status_codes:
  CHALLENGE: 401
  DENY: 403

thresholds:
  - name: minimal-suspicion
    expression: weight <= 0
    action: ALLOW

  - name: mild-suspicion
    expression:
      all:
        - weight > 0
        - weight < 10
    action: CHALLENGE
    challenge:
      algorithm: fast
      difficulty: 4

  - name: moderate-suspicion
    expression:
      all:
        - weight >= 10
        - weight < 20
    action: CHALLENGE
    challenge:
      algorithm: fast
      difficulty: 5

  - name: strong-suspicion
    expression:
      all:
        - weight >= 20
        - weight < 30
    action: CHALLENGE
    challenge:
      algorithm: fast
      difficulty: 8

  - name: extreme-suspicion
    expression: weight >= 30
    action: CHALLENGE
    challenge:
      algorithm: fast
      difficulty: 10
