# Anubis
# AI bot firewall exposed as a Traefik ForwardAuth service.
# Docs: https://anubis.techaro.lol/

# Docker image tag. Anubis does not publish a major-version floating tag,
# so this defaults to `latest`. Pin a specific version (e.g. 1.20.0) here
# if you prefer a reproducible deployment.
IMAGE_TAG=latest

# Host bind and container paths.
BIND_ADDR=127.0.0.1
BIND_PORT=8923
HOST_CONFIG_DIR=./config
HOST_DATA_DIR=./data

# External Traefik network used for forwardAuth. Anubis is reachable on
# this network as `anubis:8923` from the Traefik container.
TRAEFIK_NETWORK=traefik

# Required operational settings. The values below are examples; replace
# them with the real hostnames you protect with Anubis.
#
# REDIRECT_DOMAINS is a comma-separated list of hostnames that should be
# redirected back to after a successful challenge.
#REDIRECT_DOMAINS=app.example.com,other.example.com
#
# PUBLIC_URL is the public URL Anubis uses when rendering challenge pages
# and generating absolute redirect URLs.
#PUBLIC_URL=https://app.example.com
#
# COOKIE_DOMAIN lets the Anubis cookie be shared across subdomains, e.g.
# `.example.com` covers `app.example.com` and `other.example.com`.
#COOKIE_DOMAIN=.example.com

# Optional challenge difficulty. Anubis applies its own default when unset.
# Increase to slow down scrapers; decrease to make the challenge easier.
#DIFFICULTY=4

# Container logging.
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
