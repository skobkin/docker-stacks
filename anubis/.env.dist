# Anubis
# AI bot firewall exposed as a Traefik ForwardAuth service.
# Docs: https://anubis.techaro.lol/

# Docker image tag. Anubis does not publish a major-version floating tag,
# so this defaults to `latest`. Pin a specific version (e.g. 1.20.0) here
# if you prefer a reproducible deployment.
IMAGE_TAG=latest

# Host bind and container paths.
BIND_ADDR=127.0.0.1
BIND_PORT=8923
HOST_CONFIG_DIR=./config
HOST_DATA_DIR=./data

# Compose feature variant. `traefik` is the default and registers Anubis
# on the shared `traefik` network with a Traefik router on the host from
# `TRAEFIK_HOST`. Set to `default` to run Anubis without Traefik (you
# would then wire it up yourself).
COMPOSE_VARIANT=traefik

# Traefik integration. Same host-variable convention as Authelia.
TRAEFIK_NETWORK=traefik
TRAEFIK_HOST=anubis.example.com
TRAEFIK_ENTRYPOINTS=websecure
TRAEFIK_SERVICE_PORT=8923

# Required Anubis operational settings. The values below are examples;
# replace them with the real hostnames you protect with Anubis.
#
# REDIRECT_DOMAINS is a security allowlist. After a successful challenge,
# Anubis only redirects the browser to a hostname that appears in this
# list. Without it Anubis would behave as an open redirector and could
# be abused for phishing. List every public hostname Anubis protects,
# for example:
#   REDIRECT_DOMAINS=app.example.com,other.example.com
#
# PUBLIC_URL is the URL Traefik uses to reach the Anubis challenge
# endpoints. It must point at the public hostname from TRAEFIK_HOST
# above, including scheme, with no trailing slash. The Anubis challenge
# page issues relative redirects, but the Anubis container itself uses
# this value to construct absolute redirect URLs and to scope cookies
# to the correct host. Example:
#   PUBLIC_URL=https://anubis.example.com
#
# COOKIE_DOMAIN scopes the Anubis cookie across subdomains. A leading
# dot means the cookie is shared across all subdomains of the parent
# domain, for example `.example.com` covers `app.example.com` and
# `other.example.com`. Without it, users would have to solve the
# challenge on every subdomain. Example:
#   COOKIE_DOMAIN=.example.com

# Optional challenge difficulty. Anubis applies its own default when unset.
# Increase to slow down scrapers; decrease to make the challenge easier.
#DIFFICULTY=4

# Container logging.
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
