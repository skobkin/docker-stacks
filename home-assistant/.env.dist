# see https://www.home-assistant.io/installation/linux#install-home-assistant-container

#IMAGE_TAG=stable

HOST_CONFIG_DIR=./config

# Traefik Reverse Proxy (optional: set COMPOSE_VARIANT=traefik and uncomment TRAEFIK_HOST)
#COMPOSE_VARIANT=traefik
#TRAEFIK_HOST=homeassistant.example.com
#TRAEFIK_ENTRYPOINTS=websecure

# Access policy defaults to default-access@file. Use public-access@file only when explicitly exposing the stack.
#TRAEFIK_ACCESS_POLICY=default-access@file

#TRAEFIK_SERVICE_PORT=8123

LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
