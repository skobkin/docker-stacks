# see https://hub.docker.com/r/ollama/ollama
#OLLAMA_IMAGE_TAG=rocm
#OLLAMA_IMAGE_TAG=0.1.28-rocm
OLLAMA_IMAGE_TAG=latest

# Compose helper mode:
#   default - joins the required ai-tools network only
#   proxy - also joins the external proxy network for outbound proxying
#COMPOSE_VARIANT=default
#PROXY_NETWORK=proxy

# Ollama
HOST_OLLAMA_DATA_DIR=./data/ollama
HTTP_OLLAMA_BIND_ADDR=127.0.0.1
HTTP_OLLAMA_BIND_PORT=11434
DEV_KFD=/dev/kfd
DEV_DRI=/dev/dri

# Optional proxy env passthrough used by COMPOSE_VARIANT=proxy:
#HTTP_PROXY=http://proxy.example.com:3128
#HTTPS_PROXY=http://proxy.example.com:3128
#NO_PROXY=localhost,127.0.0.1,host.docker.internal,ollama,ollama-open-webui,faster-whisper,172.17.0.0/16,172.18.0.0/16,172.19.0.0/16,172.20.0.0/14,172.24.0.0/14,172.28.0.0/14,192.168.0.0/16

# The duration that models stay loaded in memory (default is "5m"
#OLLAMA_KEEP_ALIVE=5m

# Context length for models (64k tokens, required for OpenHands compatibility)
#OLLAMA_CONTEXT_LENGTH=65536

LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
