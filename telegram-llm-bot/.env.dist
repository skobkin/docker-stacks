# see https://hub.docker.com/r/skobkin/telegram-llm-bot

#IMAGE_TAG=0.20.0

#HOST_DATA_DIR=./data

# Telegram Bot API token from @BotFather.
TELEGRAM_TOKEN=12345

# OpenAI-compatible LLM backend. For the repo-local llama-swap stack, use the shared ai-tools network.
#LLM_BACKEND_OPENAI_COMPAT_BASE_URL=http://llama-swap:8080/v1
#LLM_BACKEND_OPENAI_COMPAT_API_TOKEN=dummy

# Model used for normal chat requests. Other feature models inherit this value when unset.
LLM_FEATURE_CHAT_MODEL=gemma4-e4b
#LLM_FEATURE_SUMMARIZE_MODEL=gemma4-e4b
#LLM_FEATURE_IMAGE_RECOGNITION_MODEL=gemma4-e4b
#LLM_FEATURE_TOOL_USE_MODEL=gemma4-e4b

# Persistent SQLite store for admin config and reminders.
#PERSISTENT_STORE_PATH=/data/db.sqlite
# Comma-separated Telegram user IDs with admin access. Empty disables admin controls.
#BOT_ADMIN_IDS=123456789,987654321

# Optional external web search for the search_web tool: none, tavily, kagi, or chain.
#SEARCH_BACKEND=none
#SEARCH_BACKEND_CHAIN=tavily,kagi
#PROVIDER_TAVILY_API_KEY=
#PROVIDER_KAGI_API_KEY=

# Runtime tuning.
#LLM_TOOL_LOOP_MAX_ITERATIONS=6
#STATE_MAX_BYTES=268435456
#STATE_HISTORY_MAX_BYTES=167772160
#STATE_HISTORY_STREAMS_MAX=1024
#STATE_IMAGE_CACHE_MAX_BYTES=67108864
#STATE_IMAGE_CACHE_TTL=24h
#LLM_UNCOMPRESSED_HISTORY_LIMIT=15
#LLM_HISTORY_SUMMARY_THRESHOLD=5
#BOT_PROCESSING_TIMEOUT=30s

#LOG_LEVEL=info
#SENTRY_DSN=

#LOG_MAX_SIZE=5m
#LOG_MAX_FILE=5
