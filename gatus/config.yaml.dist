storage:
  type: sqlite
  path: /data/db.sqlite

endpoints:
  - name: blog-wordpress
    group: 01-blog
    url: "https://skobk.in/"
    interval: 5m
    conditions:
      - "[STATUS] == 200"
      - "[CERTIFICATE_EXPIRATION] > 48h"
#    alerts:
#      - type: telegram
#      - type: ntfy

  - name: mumble-server-tls
    group: 02-services
    url: "tls://mumble.skobk.in:64738"
    interval: 1m
    conditions:
      - "[CONNECTED] == true"
      - "[CERTIFICATE_EXPIRATION] > 48h"
#    alerts:
#      - type: telegram
#      - type: ntfy

