HOST_USER=0

# Compose helper mode:
#   default - standalone host-networked status page
#   traefik - add Traefik labels while keeping network_mode: host
COMPOSE_VARIANT=default

# Optional Traefik settings used by COMPOSE_VARIANT=traefik.
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_HOST=gatus.domain.tld
TRAEFIK_SERVICE_PORT=8080
