# Fluent Bit - log collector. Ships Docker container logs to VictoriaLogs.
# https://docs.fluentbit.io/

# Docker image
#FB_IMAGE_REPOSITORY=fluent/fluent-bit
#FB_IMAGE_TAG=5.0.7

# Compose helper mode:
#   default - same host as the 'victoria-logs' stack; joins the 'logging'
#             network and uses VL_ADDRESS=victoria-logs (Docker DNS).
#   remote  - different host; does NOT join the 'logging' network.
#             VL_ADDRESS below MUST be set to a reachable IP or DNS name
#             (e.g. 192.168.1.10, vl.example.com).
#COMPOSE_VARIANT=default

# Host filesystem paths. Override only if Docker is installed in a
# non-standard location.
DOCKER_CONTAINERS_PATH=/var/lib/docker/containers
FB_STATE_PATH=./data
FLUENT_BIT_UID=0

# Destination (VictoriaLogs). For the 'remote' variant, set this to the
# LAN IP or public hostname of the host running victoria-logs, e.g.
#   VL_ADDRESS=192.168.1.10
VL_ADDRESS=victoria-logs
VL_PORT=9428

# Same-host networking
#LOGGING_NETWORK=logging

# Repo logging convention (size per rotated file, max number of files).
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5