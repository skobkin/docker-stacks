IMAGE_TAG=1.14.2
HOST_DATA_DIR=./data

# ZeroTier network ID to join on startup. Authorize the new member in ZeroTier Central after first start.
NETWORK_ID=0000000000000000

# Optional: set a fixed local service API token for zerotier-cli/API access.
#ZEROTIER_API_SECRET=

# Optional: pre-generated node identity files from zerotier-idtool.
#ZEROTIER_IDENTITY_PUBLIC=
#ZEROTIER_IDENTITY_SECRET=

LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
