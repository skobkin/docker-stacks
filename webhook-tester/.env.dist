# WebHook Tester
# https://github.com/tarampampam/webhook-tester

# Compose helper mode:
#   default - standalone localhost-bound container
#   traefik - adds Traefik labels and joins the external Traefik network
#COMPOSE_VARIANT=default

# Host binding and persistent filesystem storage
#BIND_ADDR=127.0.0.1
#BIND_PORT=8414
#HOST_DATA_DIR=./data
#HOST_UID=1000
#HOST_GID=1000

# Optional application settings
# Session lifetime. Upstream accepts values from 1m through 744h.
#SESSION_TTL=168h
# Maximum stored requests per session. Zero means unlimited.
#MAX_REQUESTS=128
# Maximum request body size in bytes. Zero means unlimited.
#MAX_REQUEST_BODY_SIZE=0
# Automatically create UUID-named sessions when their webhook URL is first used.
#AUTO_CREATE_SESSIONS=false
# Override the URL root shown for webhook endpoints, for example https://webhooks.example.com.
#PUBLIC_URL_ROOT=
#LOG_LEVEL=info
#LOG_FORMAT=json

# Optional Traefik settings used by COMPOSE_VARIANT=traefik
#TRAEFIK_NETWORK=traefik
#TRAEFIK_ENTRYPOINT=websecure

# Access defaults to default-access@file. External webhook providers usually require public-access@file.
#TRAEFIK_ACCESS_POLICY=default-access@file

TRAEFIK_HOST=webhooks.example.com

# Docker log rotation
#LOG_MAX_SIZE=5m
#LOG_MAX_FILE=5
