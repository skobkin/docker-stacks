# Remark42
# Installation: https://remark42.com/docs/getting-started/installation/
# Parameters: https://remark42.com/docs/configuration/parameters/

#IMAGE_TAG=v1.15.0

HOST_DATA_DIR=./data

# Compose helper mode:
#   default - localhost-bound standalone container
#   traefik - adds Traefik labels and joins the external Traefik network
COMPOSE_VARIANT=default

HTTP_BIND_ADDR=127.0.0.1
HTTP_BIND_PORT=8388

# Optional Traefik settings used by COMPOSE_VARIANT=traefik.
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_HOST=remark42.example.com
TRAEFIK_SERVICE_PORT=8080

# Run the container with your host UID so data files stay writable.
APP_UID=1000
TIME_ZONE=UTC

# Remark42 settings
REMARK_URL=https://remark.domain.tld
SITE=remark
SECRET=AnyLongAndHardToGuessString

# Admin IDs are provider-specific, for example github_xxx or telegram_yyy.
#ADMIN_SHARED_ID=github_xxx,telegram_yyy

# Basic auth for initial backup/import/manual admin operations only.
# Do not enable it for normal production use.
#ADMIN_PASSWD=password

# Comment settings
LOW_SCORE=-5
CRITICAL_SCORE=-10
EDIT_TIME=5m
#RESTRICTED_NAMES=your-name
#EMOJI=false
#SIMPLE_VIEW=false

DEBUG=false

# Auth settings
# Enable at least one auth method before starting Remark42.
#AUTH_ANON=true

#AUTH_GITHUB_CID=xxx
#AUTH_GITHUB_CSEC=yyy

#AUTH_GOOGLE_CID=xxx
#AUTH_GOOGLE_CSEC=yyy

#AUTH_DISCORD_CID=xxx
#AUTH_DISCORD_CSEC=yyy

#AUTH_TELEGRAM=true
#TELEGRAM_TOKEN=xxx:yyy

#AUTH_EMAIL_ENABLE=true
#AUTH_EMAIL_FROM=remark42@example.com
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_USERNAME=remark42@example.com
#SMTP_PASSWORD=xxx
#SMTP_STARTTLS=true

# Additional OAuth providers.
#AUTH_FACEBOOK_CID=xxx
#AUTH_FACEBOOK_CSEC=yyy
#AUTH_MICROSOFT_CID=xxx
#AUTH_MICROSOFT_CSEC=yyy
#AUTH_PATREON_CID=xxx
#AUTH_PATREON_CSEC=yyy
#AUTH_YANDEX_CID=xxx
#AUTH_YANDEX_CSEC=yyy

# Notifications
#NOTIFY_USERS=email
#NOTIFY_ADMINS=telegram
#NOTIFY_TELEGRAM_CHAN=xxx
# ntfy webhook example. Use the ntfy root URL; the topic is set in the JSON body.
#NOTIFY_ADMINS=webhook
#NOTIFY_WEBHOOK_URL=https://ntfy.example.com/
#NOTIFY_WEBHOOK_TEMPLATE={"topic":"remark42","title":"New Remark42 comment","message":{{.Text | escapeJSONString}},"click":{{.Locator.URL | escapeJSONString}}}
#NOTIFY_WEBHOOK_HEADERS=Content-Type:application/json,Authorization:Bearer tk_your_token_here
#NOTIFY_EMAIL_FROM=xxx
#TELEGRAM_TOKEN=xxx
#SMTP_HOST=xxx
#SMTP_PORT=xxx
#SMTP_USERNAME=xxx
#SMTP_PASSWORD=xxx
#SMTP_TLS=xxx

# SSL
# Handled using reverse-proxy
SSL_TYPE=none

# Service settings
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
