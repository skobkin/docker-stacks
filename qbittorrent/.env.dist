# User/Group mappings
PGID=1000
PUID=1000

TZ=Europe/Moscow

# Compose helper mode:
#   default - standalone host-networked container (web UI on host port 8090)
#   traefik - adds Traefik labels for routing via reverse proxy
#COMPOSE_VARIANT=default

# Optional Traefik settings used by COMPOSE_VARIANT=traefik
#TRAEFIK_HOST=qbittorrent.example.com
#TRAEFIK_ENTRYPOINT=websecure

# Access policy defaults to default-access@file. Use public-access@file only when explicitly exposing the stack.
#TRAEFIK_ACCESS_POLICY=default-access@file

#TRAEFIK_SERVICE_PORT=8090

# Web interface port
WEBUI_PORT=8090

# Volume mapping
CONFIG_PATH=./config
# This will be the same inside and outside of a container
DOWNLOAD_PATH=/mnt/downloads

# Logs
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
