# Bookwyrm configuration
# https://docs.joinbookwyrm.com/
# https://github.com/bookwyrm-social/bookwyrm
# https://hub.docker.com/r/bookwyrm/bookwyrm
#
# This file is the template. Copy it to .env before starting the stack.

# Image tag (latest is fine for non-mission-critical use; pin in production)
IMAGE_TAG=latest

# Compose helper mode:
#   default            - standalone, localhost-bound HTTP port
#   databases          - join the shared `databases` external network (central Postgres/Redis)
#   traefik            - join the shared `traefik` external network (default in this repo)
#   traefik_databases  - combine Traefik and shared databases networking
COMPOSE_VARIANT=traefik

# HTTP bind address/port for the web service (default mode only)
BIND_ADDR=127.0.0.1
BIND_PORT=8430

# Optional Traefik settings used by COMPOSE_VARIANT=traefik or traefik_databases.
# See ../_docs/traefik.md for details on these variables.
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure

# Access policy defaults to default-access@file. Use public-access@file only when
# explicitly exposing the stack to anonymous traffic.
#TRAEFIK_ACCESS_POLICY=default-access@file

TRAEFIK_HOST=example.com
TRAEFIK_SERVICE_PORT=8000
TRAEFIK_STATIC_SERVICE_PORT=80

# Optional shared database network used by COMPOSE_VARIANT=databases or traefik_databases.
# See ../_docs/databases_network.md for details.
DATABASES_NETWORK=databases

# Postgres (local stack service `db`; ignored when POSTGRES_HOST points at a central DB)
POSTGRES_USER=bookwyrm
POSTGRES_DB=bookwyrm
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_PASSWORD=
POSTGRES_SHM_SIZE=128mb

# Redis broker (Celery queue)
REDIS_BROKER_HOST=redis_broker
REDIS_BROKER_PORT=6379
REDIS_BROKER_PASSWORD=

# Redis activity (ActivityPub streaming)
REDIS_ACTIVITY_HOST=redis_activity
REDIS_ACTIVITY_PORT=6379
REDIS_ACTIVITY_PASSWORD=

# Bookwyrm Django configuration
# https://docs.joinbookwyrm.com/install-prod.html
SECRET_KEY=
DEBUG=false
DOMAIN=example.com
ALLOWED_HOSTS=example.com
CSRF_TRUSTED_ORIGINS=https://example.com
SITE_URL=https://example.com
LANGUAGE_CODE=en-us
DEFAULT_LANGUAGE=en
STATIC_ROOT=static/
MEDIA_ROOT=images/

# Bookwyrm optional tuning
# Maximum length of ActivityPub streaming responses.
MAX_STREAM_LENGTH=200
# Auto-generate book cover thumbnails locally.
ENABLE_THUMBNAIL_GENERATION=true
# Generate preview images for shared links.
ENABLE_PREVIEW_IMAGES=False
# Outbound HTTP timeouts (seconds).
SEARCH_TIMEOUT=5
QUERY_TIMEOUT=5
# Additional hosts to add to the Content-Security-Policy allow-list (comma-separated).
#CSP_ADDITIONAL_HOSTS=
# Toggle S3 storage backend (off = local filesystem).
USE_S3=false

# Local upload size in MiB. Matches the nginx sidecar's client_max_body_size and
# should be paired with a Traefik upload-* middleware (e.g. upload-100m@file).
DATA_UPLOAD_MAX_MEMORY_MiB=100

# Flower (Celery monitor) - localhost-only, not exposed via Traefik
FLOWER_USER=admin
FLOWER_PASSWORD=
FLOWER_BIND_PORT=8440

# SMTP / email - all required for user registration and password reset
# https://docs.joinbookwyrm.com/install-prod.html#email
#EMAIL_HOST=smtp.example.com
#EMAIL_PORT=587
#EMAIL_HOST_USER=
#EMAIL_HOST_PASSWORD=
#EMAIL_USE_TLS=true
#EMAIL_USE_SSL=false
#DEFAULT_FROM_EMAIL=bookwyrm@example.com

# Bind-mount paths on the host. The container-internal paths under /app
# are fixed by the upstream image; only the host-side directory changes.
PGDATA_PATH=./pgdata
BACKUPS_PATH=./backups
STATIC_PATH=./static
MEDIA_PATH=./media
EXPORTS_PATH=./exports
REDIS_BROKER_PATH=./redis_broker
REDIS_ACTIVITY_PATH=./redis_activity
NGINX_STATIC_CONFIG=./static/nginx-static.conf

# Container logging
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
