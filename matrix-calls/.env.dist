# Matrix calls stack: LiveKit SFU plus MatrixRTC authorization service.

# Docker images
# LiveKit publishes moving minor tags such as v1.12 for patch updates. Or use 'latest' if brave enough
LIVEKIT_IMAGE_TAG=v1.12
# lk-jwt-service currently documents latest as its moving Docker tag; pin this if you want bounded updates.
LK_JWT_SERVICE_IMAGE_TAG=latest

# Compose helper mode:
#   default - localhost-bound HTTP services plus public LiveKit media ports
#   traefik - adds Traefik labels and joins the external proxy network
COMPOSE_VARIANT=default

# LiveKit API/HTTP endpoint. Keep localhost-bound unless a reverse proxy handles TLS.
LIVEKIT_HTTP_BIND_ADDR=127.0.0.1
LIVEKIT_HTTP_BIND_PORT=7880

# LiveKit WebRTC ICE ports. These must be reachable by Matrix clients.
LIVEKIT_ICE_TCP_BIND_ADDR=0.0.0.0
LIVEKIT_ICE_TCP_PORT=7881
LIVEKIT_ICE_UDP_BIND_ADDR=0.0.0.0
LIVEKIT_ICE_UDP_PORT_RANGE=50100-50200
LIVEKIT_ICE_UDP_PORT_RANGE_START=50100
LIVEKIT_ICE_UDP_PORT_RANGE_END=50200
LIVEKIT_USE_EXTERNAL_IP=true

# Generate with:
# docker run --rm livekit/livekit-server:${LIVEKIT_IMAGE_TAG} generate-keys
LIVEKIT_KEY=replace-with-generated-livekit-api-key
LIVEKIT_SECRET=replace-with-generated-livekit-api-secret

# Public websocket URL used by clients and lk-jwt-service.
LIVEKIT_URL=wss://calls.example.com

# Matrix server names whose users may create LiveKit rooms.
LIVEKIT_FULL_ACCESS_HOMESERVERS=example.com

# Local JWT service port. The container always listens on 8411.
JWT_BIND_ADDR=127.0.0.1
JWT_BIND_PORT=8411

# Optional Traefik settings used by COMPOSE_VARIANT=traefik
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_HOST=calls.example.com
# Matrix clients must reach this endpoint. Set public-access@file, or an equivalent public policy, for public deployments.
#TRAEFIK_ACCESS_POLICY=public-access@file

# Container logging
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
