# Docker image. Current upstream tags are rolling "main" and immutable "sha-*".
# Pin a verified sha-* tag for immutable deployments.
IMAGE_TAG=main

# Persistent Hermes data mounted at /opt/data inside the container.
HOST_DATA_DIR=./data

# Timezone passed to the container (TZ env var) and sourced from
# /etc/localtime. Default is UTC; set to a tz database name (e.g. Europe/Moscow)
# to match the host. Hosts with a non-UTC zone should also set this so Hermes
# logs, session timestamps, and gateway messages show local time.
TZ=UTC

# Compose variant: default, proxy, api, api_proxy, traefik, traefik_proxy, traefik_api, or traefik_api_proxy.
COMPOSE_VARIANT=default
PROXY_NETWORK=proxy

# Local dashboard bind. The dashboard listens on 0.0.0.0:9119 in the container.
DASHBOARD_BIND_ADDR=127.0.0.1
DASHBOARD_BIND_PORT=8410

# Dashboard auth. This template requires a password hash; do not store plaintext.
# Generate a password hash inside the Hermes image with:
# docker compose run --rm --entrypoint /opt/hermes/.venv/bin/python hermes -c 'import sys; sys.path.insert(0, "/opt/hermes"); from plugins.dashboard_auth.basic import hash_password; print(hash_password("change-this-password"))'
# Generate a stable session secret with:
# openssl rand -hex 32
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD_HASH=replace-with-scrypt-password-hash
HERMES_DASHBOARD_BASIC_AUTH_SECRET=replace-with-random-32-byte-secret

# Security defaults. Keep explicit allowlists, avoid YOLO mode, and keep
# command approvals enabled in config.yaml.
GATEWAY_ALLOW_ALL_USERS=false
HERMES_YOLO_MODE=0
HERMES_DASHBOARD_INSECURE=0

# Local OpenAI-compatible model examples over the shared ai-tools network.
# llama-swap:
#OPENAI_BASE_URL=http://llama-swap:8080/v1
#OPENAI_API_KEY=none
# Ollama:
#OPENAI_BASE_URL=http://ollama:11434/v1
#OPENAI_API_KEY=none

# Optional proxy settings when using COMPOSE_VARIANT=proxy or a *_proxy variant.
#HTTP_PROXY=socks5://mihomo:1050
#HTTPS_PROXY=socks5://mihomo:1050
#NO_PROXY=localhost,127.0.0.1,hermes,llama-swap,ollama

# API server. Enabled only by api, api_proxy, traefik_api, and
# traefik_api_proxy variants. Generate API_SERVER_KEY with:
# openssl rand -hex 32
API_SERVER_KEY=
API_BIND_ADDR=127.0.0.1
API_BIND_PORT=8642
# Use a narrow comma-separated browser allowlist if browsers call Hermes directly.
#API_SERVER_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
#API_SERVER_MODEL_NAME=hermes-agent

# Optional Traefik routing. TRAEFIK_HOST exposes the dashboard; TRAEFIK_API_HOST
# exposes the OpenAI-compatible API server for traefik_api variants.
TRAEFIK_HOST=hermes.example.com
TRAEFIK_API_HOST=hermes-api.example.com
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_ACCESS_POLICY=default-access@file

# Resource and logging limits.
MEMORY_LIMIT=8G
CPU_LIMIT=4.0
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5

# Messaging allowlist examples. See the Hermes messaging docs for other
# platform-specific allowlists and tokens.
#TELEGRAM_BOT_TOKEN=replace-with-bot-token
#TELEGRAM_ALLOWED_USERS=123456789
#TELEGRAM_GROUP_ALLOWED_USERS=123456789
#TELEGRAM_GROUP_ALLOWED_CHATS=-1001234567890
#MATRIX_ALLOWED_USERS=@alice:matrix.example.com

# ntfy messaging example.
#NTFY_TOPIC=hermes-myname-2026
#NTFY_SERVER_URL=https://ntfy.sh
#NTFY_TOKEN=
#NTFY_ALLOWED_USERS=hermes-myname-2026
#NTFY_HOME_CHANNEL=hermes-myname-2026

# Subscription proxy note: start it manually with `hermes proxy start`.
# This stack does not route it through Traefik because upstream documents that
# the proxy has no auth of its own and accepts any bearer token.
