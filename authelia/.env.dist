# Authelia
# Docker deployment:
# https://www.authelia.com/integration/deployment/docker/
# Configuration reference:
# https://www.authelia.com/configuration/

# Docker image tag. The 4.39 tag follows the stable Authelia 4.39 release line.
IMAGE_TAG=4.39

# Compose helper mode:
#   default - localhost-bound standalone container
#   traefik - adds Traefik labels and joins the external Traefik network
#   databases - joins the shared databases network for optional Redis sessions
#   traefik_databases - combines Traefik routing and shared Redis access
COMPOSE_VARIANT=traefik

# Host bind and container paths.
HTTP_BIND_ADDR=127.0.0.1
HTTP_BIND_PORT=9091
CONFIG_PATH=./config
DATA_PATH=./data
SECRETS_PATH=./secrets

# Public Authelia portal URL and shared cookie parent domain.
# For auth.sub.domain.tld protecting svc1.sub.domain.tld, use:
#   PUBLIC_URL=https://auth.sub.domain.tld
#   SESSION_COOKIE_DOMAIN=sub.domain.tld
PUBLIC_URL=https://auth.example.com
SESSION_COOKIE_DOMAIN=example.com
DEFAULT_REDIRECTION_URL=

# Access policy applied to domains matching *.SESSION_COOKIE_DOMAIN.
# two_factor means password plus one registered second factor, such as TOTP or WebAuthn.
ACCESS_CONTROL_POLICY=two_factor

# Optional Traefik settings used by COMPOSE_VARIANT=traefik or traefik_databases.
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINTS=websecure
TRAEFIK_HOST=auth.example.com
TRAEFIK_SERVICE_PORT=9091

# Optional shared Redis sessions. To enable:
# 1. switch COMPOSE_VARIANT to databases or traefik_databases
# 2. uncomment the Redis session block in config/configuration.yml
DATABASES_NETWORK=databases
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DATABASE_INDEX=0
#REDIS_USERNAME=
#REDIS_PASSWORD=
#AUTHELIA_SESSION_REDIS_PASSWORD_FILE=/secrets/redis_password

# SMTP notifications. Authelia supports smtp or filesystem notification providers.
# Keep startup checks disabled in the template until the SMTP path is real.
SMTP_ADDRESS=smtp://smtp.example.com:587
SMTP_SENDER=Authelia <authelia@example.com>
SMTP_USERNAME=authelia@example.com
SMTP_STARTUP_CHECK_ADDRESS=admin@example.com
#AUTHELIA_NOTIFIER_SMTP_PASSWORD_FILE=/secrets/smtp_password

# Container logging.
LOG_LEVEL=info
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
