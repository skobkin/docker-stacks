# see https://docs.openwebui.com/getting-started/updating
UI_IMAGE_TAG=main

# Compose helper mode:
#   default - joins the required ai-tools network only
#   proxy - also joins the external proxy network for outbound proxying
#   traefik - adds Traefik labels and joins the external Traefik network
#   traefik_proxy - combines Traefik exposure with outbound proxy networking
#COMPOSE_VARIANT=default
# Optional Traefik settings used by COMPOSE_VARIANT=traefik or traefik_proxy.
#TRAEFIK_NETWORK=traefik
#TRAEFIK_ENTRYPOINTS=websecure

# Access policy defaults to default-access@file. Use public-access@file only when explicitly exposing the stack.
#TRAEFIK_ACCESS_POLICY=default-access@file

#TRAEFIK_HOST=open-webui.example.com
#TRAEFIK_SERVICE_PORT=8080

# Open WebUI
HOST_UI_DATA_DIR=./data/open-webui
HTTP_UI_BIND_ADDR=127.0.0.1
HTTP_UI_BIND_PORT=8010
UI_SECRET_KEY=changeme

# These connection variables are PersistentConfig values in Open WebUI.
# If you already have data in ./data/open-webui, older values may continue to win
# until you change them in the UI or set ENABLE_PERSISTENT_CONFIG=False.
ENABLE_OLLAMA_API=true
#ENABLE_OPENAI_API=true

# Open WebUI connects to sibling AI stacks over the shared ai-tools network.
# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_API_BASE_URL=http://ollama:11434/api

# llama-swap
#OPENAI_API_BASE_URL=http://llama-swap:8080/v1
#OPENAI_API_KEY=none

# STT (Whisper):
# https://docs.openwebui.com/reference/env-configuration/#speech-to-text-openai
#AUDIO_STT_ENGINE=openai
#AUDIO_STT_OPENAI_API_BASE_URL=http://faster-whisper:10300
#AUDIO_STT_MODEL=tiny-int8

#PROXY_NETWORK=proxy

# Optional proxy env passthrough used by COMPOSE_VARIANT=proxy or traefik_proxy:
#HTTP_PROXY=http://proxy.example.com:3128
#HTTPS_PROXY=http://proxy.example.com:3128
#NO_PROXY=localhost,127.0.0.1,host.docker.internal,ollama,ollama-open-webui,faster-whisper,172.17.0.0/16,172.18.0.0/16,172.19.0.0/16,172.20.0.0/14,172.24.0.0/14,172.28.0.0/14,192.168.0.0/16

LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
