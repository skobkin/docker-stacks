# https://github.com/librespeed/speedtest-rust

IMAGE_TAG=latest
COMPOSE_VARIANT=default

# Local HTTP listener.
HTTP_BIND_ADDR=127.0.0.1
HTTP_BIND_PORT=8888

# Rust backend configuration file. Copy config/configs.toml.dist to this path before starting.
HOST_CONFIG_FILE=./config/configs.toml

# Persistent storage for optional SQLite telemetry/statistics.
HOST_DATA_DIR=./data

# Optional Traefik settings used by COMPOSE_VARIANT=traefik.
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure

# Access policy defaults to default-access@file. Use public-access@file only when explicitly exposing the stack.
#TRAEFIK_ACCESS_POLICY=default-access@file

TRAEFIK_HOST=speedtest.domain.tld
#TRAEFIK_SERVICE_PORT=8080

LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
