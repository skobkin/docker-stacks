# Docker Compose settings
COMPOSE_PROJECT_NAME=stable-diffusion-webui

# User/Group IDs for file permissions
PUID=1000
PGID=1000

# Device and group configuration for GPU access
DEV_KFD=/dev/kfd
DEV_DRI=/dev/dri
GROUP_VIDEO=video
GROUP_RENDER=render

# Network binding (use 0.0.0.0 to expose externally)
BIND_IP=127.0.0.1

# Timezone (see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=Europe/Moscow

# Image tag
IMAGE_TAG=latest-cuda
# Alternative tags:
#IMAGE_TAG=latest-rocm  # For AMD GPUs
#IMAGE_TAG=latest-cpu   # For CPU only

# Logging settings
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5

# Directory configurations (relative to docker-compose.yml)
#WORKSPACE_DIR=./data/workspace
#MODELS_DIR=./data/models
#OUTPUTS_DIR=./data/outputs
#EXTENSIONS_DIR=./data/extensions
#CONFIG_DIR=./config
#CACHE_DIR=./data/cache

# Port mappings
WEBUI_PORT_HOST=7860
#WEBUI_PORT_CONTAINER=7860
JUPYTER_PORT_HOST=8899
#JUPYTER_PORT_CONTAINER=8888
SSH_PORT_HOST=2223
#SSH_PORT_CONTAINER=22

# === Stable Diffusion WebUI Configuration ===

# Auto-update A1111 Web UI on startup
AUTO_UPDATE=false

# Web UI startup arguments
# Examples:
#WEBUI_ARGS=--xformers --api
#WEBUI_ARGS=--xformers --api --medvram  # For 8GB VRAM
#WEBUI_ARGS=--xformers --api --lowvram  # For 4GB VRAM
#WEBUI_ARGS=--api --no-half --precision full  # For CPU mode
WEBUI_ARGS=

# Git reference for auto update (branch, tag, or commit hash)
# Default: latest release
#WEBUI_REF=master

# Override direct address:port with URL for Web UI
#WEBUI_URL=

# === Authentication Tokens ===

# HuggingFace token for gated models (SD3, FLUX, etc.)
# Get your token from: https://huggingface.co/settings/tokens
#HF_TOKEN=

# Civitai token for downloading gated models
# Get your token from: https://civitai.com/user/account
#CIVITAI_TOKEN=

# === Base Image Configuration ===

# Workspace settings
#WORKSPACE=/workspace
#WORKSPACE_SYNC=false

# Web authentication settings
WEB_ENABLE_AUTH=true
WEB_USER=user
# IMPORTANT: Set a strong password!
WEB_PASSWORD=changeme

# Cloudflare tunnel settings (for remote access)
#CF_TUNNEL_TOKEN=
#CF_QUICK_TUNNELS=true

# Custom provisioning script URL
#PROVISIONING_SCRIPT=

# === Advanced Settings (uncomment only if needed) ===

# GPU settings
#CUDA_VISIBLE_DEVICES=0  # Use specific GPU(s)
#NVIDIA_VISIBLE_DEVICES=all
#NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Serverless mode
#SERVERLESS=false

# Service portal settings
#SERVICEPORTAL_PORT_HOST=1111
#SERVICEPORTAL_PORT_CONTAINER=1111
#SERVICEPORTAL_METRICS_PORT=1211

# Direct address settings
#DIRECT_ADDRESS=
#DIRECT_PORT_HOST=

# Jupyter settings
#JUPYTER_TOKEN=

# SSH settings (paste your public key)
#SSH_PUBKEY=

# HTTPS/SSL settings
#CERT_NAME=
#CERT_PATH=

# Proxy settings
#PROXY_SECURE=true

# Sync settings
#SYNC_ENABLED=false

# System settings
#SKIP_ACL=false

# Debug mode
#DEBUG=false