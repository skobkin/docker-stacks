# see https://hub.docker.com/r/vectorim/element-web
#IMAGE_TAG=latest

# Compose helper mode:
#   default - standalone localhost-bound container
#   traefik - adds Traefik labels and joins the external Traefik network
#COMPOSE_VARIANT=default

HOST_USER=0

WEBUI_BIND_ADDR=127.0.0.1
WEBUI_BIND_PORT=8385

# Optional Traefik settings used by COMPOSE_VARIANT=traefik
#TRAEFIK_NETWORK=traefik
#TRAEFIK_ENTRYPOINT=websecure
#TRAEFIK_HOST=element.example.com
# Keep this aligned with the container port if you change the image or add another listener.
#TRAEFIK_SERVICE_PORT=80

LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
