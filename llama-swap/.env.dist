# Upstream documents the rolling `:vulkan` platform tag for AMD Vulkan builds.
# Use a release-specific tag here only after verifying a current Vulkan tag upstream.
IMAGE_TAG=vulkan

HOST_CONFIG_DIR=./config
HOST_MODELS_DIR=./models

HTTP_BIND_ADDR=127.0.0.1
HTTP_BIND_PORT=8011

DEV_DRI=/dev/dri
DEV_KFD=/dev/kfd

LOG_MAX_SIZE=5m
LOG_MAX_FILE=5

# Shared llama.cpp tuning used by the active config template below.
# Context sizes are split by model tier so smaller models can keep longer chats
# without forcing the larger models into the same KV cache footprint.
LLAMA_SERVER_CTX_SIZE_MAX=32768
LLAMA_SERVER_CTX_SIZE_MEDIUM=16384
LLAMA_SERVER_CTX_SIZE_MIN=8192
LLAMA_SERVER_N_GPU_LAYERS=99
LLAMA_SERVER_THREADS=8
LLAMA_SERVER_BATCH_SIZE=512
LLAMA_SERVER_UBATCH_SIZE=512

# Active GGUF filenames from config/config.yaml.dist.
GEMMA_4_E2B_GGUF=gemma-4-e2b-it-Q8_0.gguf
GEMMA_4_E4B_GGUF=gemma-4-e4b-it-Q8_0.gguf
GEMMA_4_26B_GGUF=gemma-4-26b-it-Q4_K_M.gguf
GEMMA_4_31B_GGUF=gemma-4-31b-it-Q4_K_M.gguf
QWEN_3_6_27B_GGUF=qwen-3.6-27b-instruct-q4_k_m.gguf
QWEN_3_6_35B_GGUF=qwen-3.6-35b-thinking-q4_k_m.gguf
OPENWEBUI_TITLE_GENERATOR_270M_GGUF=openwebui-title-generator-270m-q8_0.gguf

# Optional multimodal projector filenames for the commented Gemma mmproj lines.
#GEMMA_4_E2B_MMPROJ_GGUF=mmproj-gemma-4-e2b-it-f16.gguf
#GEMMA_4_E4B_MMPROJ_GGUF=mmproj-gemma-4-e4b-it-f16.gguf
#GEMMA_4_26B_MMPROJ_GGUF=mmproj-gemma-4-26b-it-f16.gguf
#GEMMA_4_31B_MMPROJ_GGUF=mmproj-gemma-4-31b-it-f16.gguf

# Optional ROCm vLLM example values used only by the commented config block.
# These must be absolute host paths because the docker run command mounts them directly.
#VLLM_IMAGE_TAG=latest
#VLLM_DEV_DRI=/dev/dri
#VLLM_DEV_KFD=/dev/kfd
#VLLM_GEMMA_4_E4B_HOST_MODEL_DIR=/absolute/path/to/gemma-4-e4b-it
#VLLM_HF_CACHE_DIR=/absolute/path/to/huggingface-cache
#VLLM_MAX_MODEL_LEN=8192
#VLLM_GPU_MEMORY_UTILIZATION=0.9
