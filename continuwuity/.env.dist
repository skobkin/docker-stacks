# Continuwuity
# Docker docs:
# https://raw.githubusercontent.com/continuwuity/continuwuity/refs/heads/main/docs/deploying/docker.mdx
# Environment variables reference:
# https://raw.githubusercontent.com/continuwuity/continuwuity/refs/heads/main/docs/reference/environment-variables.mdx

# Docker image
IMAGE_REPOSITORY=forgejo.ellis.link/continuwuation/continuwuity
# Possible tags:
# - latest (latest stable/release image; safest default)
# - main (latest main-branch build; use for testing newer upstream changes)
# - latest-maxperf (latest stable/release image with performance-focused build options; on amd64 this targets Haswell-class CPUs or newer and is the best choice when your hardware supports it and you want maximum RocksDB/federation performance)
# - main-maxperf (main-branch performance-focused build; on amd64 this also targets Haswell-class CPUs or newer, and should be used only if you want both unreleased changes and the more aggressive performance build)
# Prefer non-`maxperf` tags if you want the most conservative upstream default, if you are unsure about CPU compatibility, or if your amd64 CPU is older than Haswell.
IMAGE_TAG=latest-maxperf

# Compose helper mode:
#   default               - localhost-bound reverse-proxy-friendly setup
#   traefik               - adds Traefik labels and joins external proxy network
#   host_resolver         - mounts host /etc/resolv.conf for Docker DNS issues
#   traefik_host_resolver - combines both options above
COMPOSE_VARIANT=default

# Host bindings and local paths
HTTP_BIND_ADDR=127.0.0.1
HTTP_BIND_PORT=6167
DATA_PATH=./data
CONFIG_PATH=./config
BACKUPS_PATH=./backups

# Optional Traefik settings used by COMPOSE_VARIANT=traefik*
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
# Primary Matrix hostname served by Traefik for this stack.
TRAEFIK_MATRIX_HOST=matrix.example.com
# Hostname that should serve /.well-known/matrix/* through Traefik.
# Delegated default: keep this at the apex domain.
# Strict subdomain-only or apex-direct mode: set this to the same value as TRAEFIK_MATRIX_HOST
# unless you intentionally want a separate delegated discovery host.
TRAEFIK_WELL_KNOWN_HOST=example.com

# Container logging
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5

##### Continuwuity configuration

# Delegated default:
# - user IDs are @user:example.com
# - Continuwuity is reverse-proxied on matrix.example.com
# - /.well-known/matrix/* is served for example.com
CONTINUWUITY_SERVER_NAME=example.com
CONTINUWUITY_DATABASE_PATH=/var/lib/continuwuity
CONTINUWUITY_ADDRESS=0.0.0.0
CONTINUWUITY_PORT=6167
CONTINUWUITY_ALLOW_REGISTRATION=true
CONTINUWUITY_ALLOW_FEDERATION=true
CONTINUWUITY_TRUSTED_SERVERS=["matrix.org"]
# Matrix client discovery hint for delegated setups such as example.com -> https://matrix.example.com.
# Not needed when CONTINUWUITY_SERVER_NAME already matches the real homeserver host.
CONTINUWUITY_WELL_KNOWN__CLIENT=https://matrix.example.com
# Matrix federation discovery hint for delegated setups such as example.com -> matrix.example.com:443.
# Also useful in subdomain-only setups when you want federation to use HTTPS on port 443
# instead of exposing the Matrix federation port 8448.
CONTINUWUITY_WELL_KNOWN__SERVER=matrix.example.com:443

# Optional max request size in bytes for uploads and other incoming requests.
# Keep the matching reverse-proxy request/body limit slightly higher to avoid proxy-side rejections.
# Upstream default is 20971520 (~20 MiB).
#CONTINUWUITY_MAX_REQUEST_SIZE=20971520

# Logging
#CONTINUWUITY_LOG=info

# Optional support metadata for /.well-known/matrix/support
#CONTINUWUITY_WELL_KNOWN__SUPPORT_PAGE=https://example.com/support
#CONTINUWUITY_WELL_KNOWN__SUPPORT_EMAIL=admin@example.com
#CONTINUWUITY_WELL_KNOWN__SUPPORT_MXID=@admin:example.com

# Optional online RocksDB backups.
# The backup directory is already mounted, but backups stay disabled until this is set.
#CONTINUWUITY_DATABASE_BACKUP_PATH=/var/lib/continuwuity-backups
#CONTINUWUITY_DATABASE_BACKUPS_TO_KEEP=3

# Optional switch to a TOML config file inside ./config
#CONTINUWUITY_CONFIG=/etc/continuwuity/continuwuity.toml

# Host layout alternatives:
# 1. Matrix subdomain only:
#    CONTINUWUITY_SERVER_NAME=matrix.example.com
#    comment out CONTINUWUITY_WELL_KNOWN__CLIENT
#    keep CONTINUWUITY_WELL_KNOWN__SERVER=matrix.example.com:443 if federation should use 443
#    comment out CONTINUWUITY_WELL_KNOWN__SERVER only if you intentionally expose federation on 8448
#    TRAEFIK_MATRIX_HOST=matrix.example.com
#    TRAEFIK_WELL_KNOWN_HOST=matrix.example.com
#
# 2. Apex domain only:
#    CONTINUWUITY_SERVER_NAME=example.com
#    comment out CONTINUWUITY_WELL_KNOWN__CLIENT
#    comment out CONTINUWUITY_WELL_KNOWN__SERVER
#    TRAEFIK_MATRIX_HOST=example.com
#    TRAEFIK_WELL_KNOWN_HOST=example.com
#    point your reverse proxy directly at the apex domain instead of matrix.example.com
