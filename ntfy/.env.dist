# ntfy
# Docker installation:
# https://docs.ntfy.sh/install/
# Configuration reference:
# https://docs.ntfy.sh/config/

# Docker image tag.
# Docker Hub currently publishes recent tags such as v2.21; the stack defaults to the stable major tag.
IMAGE_TAG=v2

# Compose helper mode:
#   default - localhost-bound standalone container
#   traefik - adds Traefik labels and joins the external Traefik network
COMPOSE_VARIANT=default

# Host bind and container listen settings.
HTTP_BIND_ADDR=127.0.0.1
HTTP_BIND_PORT=8405
NTFY_LISTEN_PORT=8080

# Host paths.
HOST_DATA_DIR=./data
HOST_CACHE_DIR=./data/cache

# Run the container with your host UID/GID so SQLite and cache files stay writable.
HOST_UID=1000
HOST_GID=1000

# Optional Traefik settings used by COMPOSE_VARIANT=traefik.
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_HOST=ntfy.example.com
# Keep this aligned with NTFY_LISTEN_PORT if you change the internal listener.
TRAEFIK_SERVICE_PORT=8080

# Container logging.
LOG_MAX_SIZE=5m
LOG_MAX_FILE=5

##### ntfy configuration

# Public base URL used in links, attachment URLs, Web Push, and reverse-proxy setups.
NTFY_BASE_URL=https://ntfy.example.com

# Listen on a non-privileged port inside the container so the stack can run as a non-root user.
NTFY_LISTEN_HTTP=:8080

# Private-by-default auth setup backed by SQLite.
NTFY_AUTH_FILE=/var/lib/ntfy/user.db
NTFY_AUTH_DEFAULT_ACCESS=deny-all
NTFY_ENABLE_LOGIN=true
NTFY_ENABLE_SIGNUP=false

# Persistent message cache. Required for poll/since retrieval.
NTFY_CACHE_FILE=/var/cache/ntfy/cache.db
NTFY_CACHE_DURATION=48h

# Logging.
#NTFY_LOG_LEVEL=INFO
#NTFY_LOG_FORMAT=text

# Optional attachment support.
# Requires NTFY_BASE_URL and a writable cache directory.
#NTFY_ATTACHMENT_CACHE_DIR=/var/cache/ntfy/attachments
#NTFY_ATTACHMENT_TOTAL_SIZE_LIMIT=5G
#NTFY_ATTACHMENT_FILE_SIZE_LIMIT=15M
#NTFY_ATTACHMENT_EXPIRY_DURATION=3h

# Optional Web Push support for browsers.
# Generate keys with:
#   docker compose run --rm ntfy webpush keys
#NTFY_WEB_PUSH_PUBLIC_KEY=
#NTFY_WEB_PUSH_PRIVATE_KEY=
#NTFY_WEB_PUSH_FILE=/var/cache/ntfy/webpush.db
#NTFY_WEB_PUSH_EMAIL_ADDRESS=admin@example.com

# Optional SMTP notifications (`X-Email`) support.
#NTFY_SMTP_SENDER_ADDR=smtp.example.com:587
#NTFY_SMTP_SENDER_USER=ntfy@example.com
#NTFY_SMTP_SENDER_PASS=<change_me>
#NTFY_SMTP_SENDER_FROM=ntfy@example.com

# Optional SMTP publishing support.
#NTFY_SMTP_SERVER_LISTEN=:25
#NTFY_SMTP_SERVER_DOMAIN=ntfy.example.com
#NTFY_SMTP_SERVER_ADDR_PREFIX=ntfy-

# Optional iOS instant notifications via ntfy.sh or another upstream.
# Keep disabled unless you intentionally want upstream poll requests.
#NTFY_UPSTREAM_BASE_URL=https://ntfy.sh
#NTFY_UPSTREAM_ACCESS_TOKEN=
