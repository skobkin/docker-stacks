# Forgejo MCP image tag. "latest" follows the most recent upstream release.
IMAGE_TAG=latest

# Compose variant: default, proxy, traefik, or traefik_proxy.
COMPOSE_VARIANT=default
PROXY_NETWORK=proxy

# Optional Traefik settings used by COMPOSE_VARIANT=traefik or traefik_proxy.
#TRAEFIK_HOST=mcp-forgejo.example.com
#TRAEFIK_NETWORK=traefik
#TRAEFIK_ENTRYPOINT=websecure

# Access policy defaults to default-access@file. Use public-access@file only
# when intentionally exposing this authenticated MCP endpoint publicly.
#TRAEFIK_ACCESS_POLICY=default-access@file

# Forgejo instance served by this MCP endpoint.
FORGEJO_URL=https://forgejo.example.com

# Optional global fallback identity. When unset, every client request must send
# its own token in the Authorization header.
#FORGEJO_ACCESS_TOKEN=replace-with-forgejo-access-token

# Local HTTP endpoint. Keep the default localhost binding unless access is
# protected by another network layer.
BIND_ADDR=127.0.0.1
BIND_PORT=8412

# Optional Mihomo proxy settings used with COMPOSE_VARIANT=proxy.
#HTTP_PROXY=socks5://mihomo:1050
#HTTPS_PROXY=socks5://mihomo:1050
#NO_PROXY=localhost,127.0.0.1,mcp-forgejo

LOG_MAX_SIZE=5m
LOG_MAX_FILE=5
